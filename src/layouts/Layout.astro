---
import '../styles/global.css'
import SplashScreen from '../components/SplashScreen.astro';

interface Props {
  title: string;
  description?: string;
  showSplash?: boolean;
}

// showSplash por defecto es false — solo la home lo activa explícitamente
const { title, description = "UX/UI Designer & Developer - Creando experiencias digitales memorables", showSplash = false } = Astro.props;
---

<!DOCTYPE html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/png" href="/favicon.png" />
    
    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,500;0,600;0,700;1,400;1,500;1,600&family=Inter:wght@300;400;500;600&family=Space+Grotesk:wght@400;500;600;700&display=swap" rel="stylesheet">
    
    <title>{title}</title>
  </head>
  <body class="antialiased">
    <!-- Noise overlay -->
    <div class="noise"></div>
    
    <!-- Custom cursor -->
    <div class="cursor hidden lg:block" id="cursor"></div>
    
    <!-- Page transition overlay (para navegación entre páginas, z inferior al splash) -->
    <div class="page-transition fixed inset-0 bg-[var(--color-primary)] z-[9998] transform translate-y-full pointer-events-none" id="page-transition"></div>

    <!-- Splash Screen (solo en home) -->
    {showSplash && <SplashScreen />}

    <!-- WhatsApp widget -->
    <a
      id="wsp-widget"
      href="https://wa.me/51989312330?text=Hola%20Julisa%2C%20vi%20tu%20portfolio%20y%20me%20gustar%C3%ADa%20contactarte"
      target="_blank"
      rel="noopener noreferrer"
      aria-label="Contactar por WhatsApp"
    >
      <!-- Ícono oficial WhatsApp -->
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
        <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
      </svg>
    </a>

    <style>
      #wsp-widget {
        position: fixed;
        bottom: 2rem;
        right: 2rem;
        z-index: 9990;
        width: 3rem;
        height: 3rem;
        background: #25D366;
        color: #fff;
        border-radius: 9999px;
        display: flex;
        align-items: center;
        justify-content: center;
        box-shadow: 0 4px 20px rgba(37, 211, 102, 0.35);
        opacity: 0;
        pointer-events: none;
        transform: translateY(10px);
        transition: opacity 0.4s cubic-bezier(0.16, 1, 0.3, 1),
                    transform 0.4s cubic-bezier(0.16, 1, 0.3, 1),
                    box-shadow 0.25s cubic-bezier(0.16, 1, 0.3, 1);
      }

      #wsp-widget.wsp-visible {
        opacity: 1;
        pointer-events: auto;
        transform: translateY(0);
      }

      #wsp-widget svg {
        width: 1.5rem;
        height: 1.5rem;
      }

      #wsp-widget.wsp-visible:hover {
        transform: scale(1.1);
        box-shadow: 0 6px 28px rgba(37, 211, 102, 0.5);
      }

      @media (max-width: 767px) {
        #wsp-widget {
          bottom: 1.25rem;
          right: 1.25rem;
          width: 2.75rem;
          height: 2.75rem;
        }
      }
    </style>

    <script>
      // Mostrar widget de WhatsApp solo después de salir del hero
      const wspWidget = document.getElementById('wsp-widget');
      if (wspWidget) {
        const heroSection = document.querySelector('[data-hero="home"]');
        if (heroSection) {
          const observer = new IntersectionObserver(
            (entries) => {
              entries.forEach(entry => {
                if (!entry.isIntersecting) {
                  wspWidget.classList.add('wsp-visible');
                } else {
                  wspWidget.classList.remove('wsp-visible');
                }
              });
            },
            { threshold: 0.1 }
          );
          observer.observe(heroSection);
        } else {
          // En páginas sin hero, mostrar siempre
          wspWidget.classList.add('wsp-visible');
        }
      }
    </script>
    
    <slot />

    <!-- Lenis Smooth Scroll -->
    <script>
      import Lenis from 'lenis';
      
      // Mark that JavaScript is loaded - for progressive enhancement
      document.documentElement.classList.add('js-loaded');
      
      // Detect if user is on mobile
      const isMobile = /Android|webOS|iPhone|iPad|iPod|BlackBerry|IEMobile|Opera Mini/i.test(navigator.userAgent);
      
      const lenis = new Lenis({
        duration: isMobile ? 1.0 : 1.2, // Faster on mobile for better responsiveness
        easing: (t) => Math.min(1, 1.001 - Math.pow(2, -10 * t)),
        orientation: 'vertical',
        gestureOrientation: 'vertical',
        smoothWheel: !isMobile, // Disable smooth wheel on mobile for better performance
        touchMultiplier: 2, // More responsive touch scrolling
        infinite: false,
      });

      function raf(time: number) {
        lenis.raf(time);
        requestAnimationFrame(raf);
      }

      requestAnimationFrame(raf);
      
      // Make lenis available globally for ScrollTrigger integration
      (window as any).lenis = lenis;
    </script>

    <!-- GSAP Advanced Animations -->
    <script>
      import gsap from 'gsap';
      import { ScrollTrigger } from 'gsap/ScrollTrigger';
      
      gsap.registerPlugin(ScrollTrigger);
      
      // Sync ScrollTrigger with Lenis
      const lenis = (window as any).lenis;
      if (lenis) {
        lenis.on('scroll', ScrollTrigger.update);
        gsap.ticker.add((time) => {
          lenis.raf(time * 1000);
        });
        gsap.ticker.lagSmoothing(0);
      }

      // Custom cursor with magnetic effect
      const cursor = document.getElementById('cursor');
      
      if (cursor && window.innerWidth > 1024) {
        let mouseX = 0;
        let mouseY = 0;
        let cursorX = 0;
        let cursorY = 0;
        let isHovering = false;

        document.addEventListener('mousemove', (e) => {
          mouseX = e.clientX;
          mouseY = e.clientY;
        });

        gsap.ticker.add(() => {
          const speed = isHovering ? 0.2 : 0.15;
          cursorX += (mouseX - cursorX) * speed;
          cursorY += (mouseY - cursorY) * speed;
          gsap.set(cursor, {
            x: cursorX - 10,
            y: cursorY - 10,
          });
        });

        // Enhanced hover effect on interactive elements
        const interactiveElements = document.querySelectorAll('a, button, .interactive, .project-card');
        interactiveElements.forEach(el => {
          el.addEventListener('mouseenter', () => {
            cursor.classList.add('is-hovering');
            isHovering = true;
          });
          el.addEventListener('mouseleave', () => {
            cursor.classList.remove('is-hovering');
            isHovering = false;
          });
        });
        
        // Magnetic effect for buttons
        const magneticButtons = document.querySelectorAll('.magnetic, .nav-cta');
        magneticButtons.forEach(btn => {
          btn.addEventListener('mousemove', (e) => {
            const rect = (btn as HTMLElement).getBoundingClientRect();
            const x = (e as MouseEvent).clientX - rect.left - rect.width / 2;
            const y = (e as MouseEvent).clientY - rect.top - rect.height / 2;
            
            gsap.to(btn, {
              x: x * 0.3,
              y: y * 0.3,
              duration: 0.4,
              ease: 'power2.out'
            });
          });
          
          btn.addEventListener('mouseleave', () => {
            gsap.to(btn, {
              x: 0,
              y: 0,
              duration: 0.7,
              ease: 'elastic.out(1, 0.3)'
            });
          });
        });
      }

      // Advanced reveal animations with stagger
      // Skip: img-reveal (has its own CSS transitions) + hero elements (have their own GSAP timeline in Hero.astro)
      const revealElements = document.querySelectorAll('.reveal:not(.img-reveal)');
      
      revealElements.forEach(el => {
        const delay = (el as HTMLElement).dataset.delay ? parseFloat((el as HTMLElement).dataset.delay!) : 0;
        
        // Skip elements inside the HOME hero — it has its own dedicated GSAP timeline in Hero.astro
        const isInHomeHero = (el as HTMLElement).closest('[data-hero="home"]') !== null;
        if (isInHomeHero) return;

        // If the element is already in the viewport on load, animate it immediately (e.g. project case study hero)
        const rect = (el as HTMLElement).getBoundingClientRect();
        const alreadyVisible = rect.top < window.innerHeight * 0.95;

        if (alreadyVisible) {
          gsap.fromTo(el,
            { opacity: 0, y: 80, scale: 0.95 },
            { opacity: 1, y: 0, scale: 1, duration: 1.2, delay: delay, ease: 'expo.out' }
          );
          return;
        }
        
        gsap.fromTo(el, 
          {
            opacity: 0,
            y: 80,
            scale: 0.95
          },
          {
            opacity: 1,
            y: 0,
            scale: 1,
            duration: 1.2,
            delay: delay,
            ease: 'expo.out',
            scrollTrigger: {
              trigger: el,
              start: 'top 85%',
              toggleActions: 'play none none none'
            }
          }
        );
      });

      // Parallax for images with img-reveal
      const parallaxImages = document.querySelectorAll('.img-reveal');

      parallaxImages.forEach(container => {
        const img = container.querySelector('img');
        const delay = (container as HTMLElement).dataset.delay
          ? parseFloat((container as HTMLElement).dataset.delay!) * 1000
          : 0;

        // CSS transition handles the reveal animation; JS only adds the class
        ScrollTrigger.create({
          trigger: container,
          start: 'top 88%',
          once: true,
          onEnter: () => {
            setTimeout(() => container.classList.add('is-visible'), delay);
          }
        });

        if (img) {
          // Subtle parallax on scroll (only after reveal)
          gsap.to(img, {
            yPercent: 8,
            ease: 'none',
            scrollTrigger: {
              trigger: container,
              start: 'top bottom',
              end: 'bottom top',
              scrub: 1.5
            }
          });
        }
      });

      // Text split animation for headings
      const splitHeadings = document.querySelectorAll('.split-text');
      
      splitHeadings.forEach(heading => {
        const text = heading.textContent || '';
        const words = text.split(' ');
        heading.innerHTML = words.map(word => 
          `<span class="word-wrapper inline-block overflow-hidden"><span class="word inline-block">${word}</span></span>`
        ).join(' ');
        
        const wordElements = heading.querySelectorAll('.word');
        
        gsap.fromTo(wordElements,
          { y: '100%', opacity: 0 },
          {
            y: '0%',
            opacity: 1,
            duration: 1,
            stagger: 0.05,
            ease: 'expo.out',
            scrollTrigger: {
              trigger: heading,
              start: 'top 85%',
              toggleActions: 'play none none none'
            }
          }
        );
      });

      // Horizontal scroll animation for sections
      const horizontalSections = document.querySelectorAll('.horizontal-scroll');
      
      horizontalSections.forEach(section => {
        const container = section.querySelector('.horizontal-container');
        if (container) {
          const scrollWidth = (container as HTMLElement).scrollWidth - window.innerWidth;
          
          gsap.to(container, {
            x: -scrollWidth,
            ease: 'none',
            scrollTrigger: {
              trigger: section,
              start: 'top top',
              end: () => `+=${scrollWidth}`,
              scrub: 1,
              pin: true,
              anticipatePin: 1
            }
          });
        }
      });

      // Stagger animation for grid items
      const staggerGrids = document.querySelectorAll('.stagger-grid');
      
      staggerGrids.forEach(grid => {
        const items = grid.children;
        
        gsap.fromTo(items,
          { 
            opacity: 0, 
            y: 60,
            scale: 0.9
          },
          {
            opacity: 1,
            y: 0,
            scale: 1,
            duration: 0.5,
            stagger: 0.06,
            ease: 'expo.out',
            scrollTrigger: {
              trigger: grid,
              start: 'top 80%',
              toggleActions: 'play none none none'
            }
          }
        );
      });

      // Counter animation for numbers
      const counters = document.querySelectorAll('.counter');
      
      counters.forEach(counter => {
        const target = parseInt((counter as HTMLElement).dataset.target || '0');
        
        ScrollTrigger.create({
          trigger: counter,
          start: 'top 85%',
          onEnter: () => {
            gsap.to(counter, {
              innerText: target,
              duration: 2,
              snap: { innerText: 1 },
              ease: 'power2.out'
            });
          }
        });
      });

      // Section divider animation
      const dividers = document.querySelectorAll('.section-divider');
      
      dividers.forEach(divider => {
        gsap.fromTo(divider,
          { scaleX: 0 },
          {
            scaleX: 1,
            duration: 1.5,
            ease: 'expo.out',
            scrollTrigger: {
              trigger: divider,
              start: 'top 85%',
              toggleActions: 'play none none none'
            }
          }
        );
      });

      // Refresh ScrollTrigger after all images load + reveal any missed elements
      window.addEventListener('load', () => {
        ScrollTrigger.refresh();
        // Fallback: show any img-reveal elements already in viewport that weren't triggered
        document.querySelectorAll('.img-reveal:not(.is-visible)').forEach(el => {
          const rect = el.getBoundingClientRect();
          if (rect.top < window.innerHeight) {
            el.classList.add('is-visible');
          }
        });
      });
    </script>
  </body>
</html>
