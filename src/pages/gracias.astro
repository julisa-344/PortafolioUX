---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<Layout
  title="Mensaje recibido | Julisa - UX/UI Designer & Developer"
  description="Gracias por ponerte en contacto. Te responderé pronto."
  canonicalPath="/gracias"
>
  <Header />

  <main class="min-h-screen flex flex-col">

    <!-- Thank you section — centrada verticalmente -->
    <section class="flex-1 flex flex-col justify-center px-6 md:px-12 lg:px-24 py-32">
      <div class="max-w-[1600px] mx-auto w-full">

        <!-- Meta row -->
        <div class="flex items-center gap-3 mb-12 reveal" data-delay="0">
          <span class="w-6 h-[1px] bg-[var(--color-secondary)]"></span>
          <span class="text-[var(--color-text-muted)] text-xs uppercase tracking-[0.3em]">Mensaje recibido</span>
        </div>

        <!-- Separador -->
        <div class="h-[1px] w-full bg-[var(--color-border)] mb-12 reveal" data-delay="0.05"></div>

        <!-- Título grande -->
        <h1
          class="reveal font-display font-semibold leading-[0.9] mb-0"
          data-delay="0.1"
          style="font-size: clamp(4rem, 12vw, 11rem);"
        >
          Gracias.
        </h1>

        <!-- Separador full rojo -->
        <div class="h-[1px] w-full bg-[var(--color-primary)] mt-8 mb-12 reveal" data-delay="0.2"></div>

        <!-- Mensaje + CTA en grid -->
        <div class="grid grid-cols-1 lg:grid-cols-[1fr_1fr] gap-12 lg:gap-40 items-end">

          <!-- Mensaje -->
          <div class="reveal" data-delay="0.3">
            <p class="text-[var(--color-text-muted)] text-lg leading-relaxed max-w-md">
              Tu mensaje está en mis manos. Te responderé a la brevedad — normalmente en menos de 24 horas.
            </p>
          </div>

          <!-- CTAs -->
          <div class="reveal flex flex-col sm:flex-row gap-4 lg:justify-end" data-delay="0.4">
            <a
              href="/"
              class="group inline-flex items-center gap-3 px-8 py-4 bg-[var(--color-primary)] text-[#FDF8F3] text-sm uppercase tracking-[0.2em] font-medium transition-all duration-300 hover:gap-5"
            >
              Volver al inicio
              <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 transition-transform duration-300 group-hover:translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
              </svg>
            </a>
            <a
              href="/work"
              class="group inline-flex items-center gap-3 px-8 py-4 border border-[var(--color-border)] text-sm uppercase tracking-[0.2em] font-medium transition-all duration-300 hover:border-[var(--color-primary)] hover:text-[var(--color-primary)] hover:gap-5"
            >
              Ver proyectos
              <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 transition-transform duration-300 group-hover:translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
              </svg>
            </a>
          </div>

        </div>

      </div>
    </section>

  </main>

  <Footer />
</Layout>
