---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Hero from '../components/Hero.astro';
import StatsBar from '../components/StatsBar.astro';
import MarqueeRibbon from '../components/MarqueeRibbon.astro';
import ProjectsGrid from '../components/ProjectsGrid.astro';
import About from '../components/About.astro';
import Footer from '../components/Footer.astro';

// Proyectos destacados - Aquí conectarás con tus proyectos reales
const featuredProjects = [
  {
    slug: 'intense',
    title: 'Intense Viajes',
    category: 'Plataforma de Viajes',
    tags: ['UX Research', 'Wireframes', 'Sitemap'],
    thumbnail: '/images/projects/intense/portadaCard.png',
    year: '2025',
    featured: true,
  },
  {
    slug: 'sandra-jordan',
    title: 'Sandra Jordan Prima Alpaca',
    category: 'E-commerce de Lujo',
    tags: ['UX Design', 'UI Design', 'E-commerce'],
    thumbnail: '/images/projects/sandra-jordan/portadacard.webp',
    year: '2024',
    featured: true,
  },

];

// Habilidades organizadas por categoría
const skills = [
  {
    name: 'UX Research',
    items: ['Benchmark', 'User Interviews', 'Sitemap', 'User Flows', 'Wireframes', 'Prototyping'],
  },
  {
    name: 'UI Design',
    items: ['Design Systems', 'Visual Design', 'Responsive Design', 'Figma', 'Adobe XD'],
  },
  {
    name: 'Development',
    items: ['React', 'Next.js', 'Vue.js', 'HTML/CSS', 'JavaScript'],
  },
  {
    name: 'Soft Skills',
    items: ['Client Meetings', 'Presentations', 'Problem Solving', 'Team Collaboration'],
  },
];
---

<Layout title="Julisa | UX/UI Designer & Developer" showSplash={true}>
  <Header />
  
  <main>
    <Hero 
      title="~Diseño digital que se/ ENTIENDE, SIENTE Y conecta."
      subtitle="Product Designer & Frontend Developer"
    >
      Transformo problemas complejos en interfaces claras
      y funcionales — desde la investigación hasta el código,
      con intención detrás de cada decisión.
    </Hero>

    <StatsBar />

    <MarqueeRibbon text="UX Design · UI Design · Development" speed={25} />

    <ProjectsGrid projects={featuredProjects} />

    <About skills={skills} />
  </main>

  <Footer />
</Layout>
