---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import DesktopShowcase from '../../components/DesktopShowcase.astro';
import MobileShowcase from '../../components/MobileShowcase.astro';
import FloatingElements from '../../components/FloatingElements.astro';

// Datos del proyecto Intense Peru
const project = {
  title: 'Intense Peru',
  subtitle: 'Rediseño Web para Agencia de Viajes Boutique',
  year: '2025',
  client: 'Intense Peru @ Nerd',
  role: 'UX/UI Designer',
  duration: '4+ meses',
  tools: ['Figma', 'FigJam', 'Claude', 'ChatGPT', 'Gemini', 'Pencil'],
  tags: ['UX Research', 'UI Design', 'Rediseño'],
  overview: 'Rediseño del sitio web para Intense Peru, agencia de viajes boutique con itinerarios exclusivos dirigidos a los mercados de Estados Unidos, México e Italia. El proyecto partió desde cero: kick-off con el cliente, recepción del brief, benchmark de competidores (directos, indirectos, nacionales e internacionales), sitemap, wireframes y UI Design.',
  challenge: 'El cliente quería un diseño de lujo, de muy alta fidelidad — algo que comunicara exclusividad desde el primer vistazo. El reto no fue solo el diseño en sí, sino también liderar reuniones con distintos interlocutores del cliente, presentar y justificar las decisiones de diseño frente a distintas perspectivas, y mantener el foco en los objetivos del usuario.',
  goals: [
    'Transmitir exclusividad y lujo desde el primer vistazo',
    'Definir la identidad tipográfica del proyecto',
    'Estructurar la arquitectura de información del sitio completo',
    'Diseñar wireframes de todas las pantallas y flujos',
    'Priorizar "Design your Trip" e itinerarios como eje central del sitio'
  ],
  process: [
    {
      phase: 'Research',
      title: 'Kick-off y Benchmark',
      description: 'El proyecto arrancó con un kick-off donde recibí el brief del cliente. Luego realicé un benchmark exhaustivo analizando competidores directos e indirectos, nacionales e internacionales: Abercrombie & Kent, Kuoda, Aracari, Belmond y otros referentes de viajes de lujo. El objetivo fue entender cómo las mejores marcas comunican exclusividad y qué patrones de diseño generan confianza en el usuario.',
      image: '/images/projects/intense/beanchmark.webp'
    },
    {
      phase: 'Sitemap',
      title: 'Arquitectura de Información',
      description: 'Definí la estructura del sitio desde cero, priorizando las páginas de itinerarios y la sección "Design your Trip" como ejes centrales de conversión. Organicé el contenido para facilitar el descubrimiento de destinos y journeys, con flujos que apuntaban hacia el contacto directo y la cotización personalizada.',
      image: '/images/projects/intense/sitemap.webp'
    },
    {
      phase: 'Wireframes',
      title: 'Wireframes y Flujos',
      description: 'Diseñé los wireframes de todas las pantallas del sitio — sin excepción — para validar la estructura antes de pasar al diseño visual. Se prestó especial atención a los itinerarios (que manejaban mucha información) y a "Design your Trip", el flujo más complejo del proyecto. Esta etapa también implicó presentar y defender cada decisión de diseño frente al equipo del cliente.',
      image: '/images/projects/intense/wireframes.webp'
    },
    {
      phase: 'UI Design',
      title: 'Tipografía y UI',
      description: 'Definí la identidad tipográfica del proyecto y la apliqué a las pantallas, construyendo una interfaz premium inspirada en la estética Belmond: limpia, con mucho peso visual en las imágenes y textos reducidos. Incorporé las imágenes en la estructura, aunque su selección y refinamiento final fue continuado con el cliente.',
      image: '/images/projects/intense/portadaCard.png'
    }
  ],
  highlights: [
    'Proyecto desde cero: kick-off, brief, benchmark, sitemap, wireframes y UI',
    'Identidad tipográfica definida para la marca',
    'Diseño visual premium con énfasis en imágenes de alta calidad',
    '"Design your Trip" como eje central: flujo de itinerarios personalizados',
    'Wireframes de absolutamente todas las pantallas del sitio'
  ],
  testimonial: {
    quote: 'Julisa formó parte del equipo de trabajo que nos apoyó en el desarrollo de nuestra nueva página web. Realizó un excelente trabajo en la maquetación y diseño. Destacó por su gran creatividad y por desarrollar cada propuesta bajo un concepto claramente enfocado en el cliente, cuidando tanto la estética como la experiencia de usuario. Su aporte fue clave para lograr un resultado alineado con nuestros objetivos, demostrando profesionalismo, compromiso y gran atención a los detalles. Sin duda, recomendamos su trabajo.',
    author: 'Juan Pablo Arce',
    authorUrl: 'https://www.linkedin.com/in/juan-pablo-arce-70739b35/',
    role: 'Intense Perú'
  },
  nextProject: {
    slug: 'sandra-jordan',
    title: 'Sandra Jordan Prima Alpaca'
  },
  desktopShowcase: {
    mainPages: [
      { src: '/images/projects/intense/HOME.png', label: 'Home', alt: 'Intense Peru - Página principal', url: 'intenseperu.com' },
      { src: '/images/projects/intense/DESTINATIONS.png', label: 'Destinos', alt: 'Intense Peru - Página de destinos', url: 'intenseperu.com/destinations' }
    ],
    journeysPages: [
      { src: '/images/projects/intense/Journeys.png', label: 'Journeys', alt: 'Intense Peru - Todos los viajes', url: 'intenseperu.com/journeys' },
      { src: '/images/projects/intense/itinerary.png', label: 'Itinerario', alt: 'Intense Peru - Detalle de itinerario', url: 'intenseperu.com/itinerary' }
    ],
    contentPages: [
      { src: '/images/projects/intense/BLOG.png', label: 'Blog', alt: 'Intense Peru - Blog de viajes', url: 'intenseperu.com/blog' },
      { src: '/images/projects/intense/CONTACT.png', label: 'Contacto', alt: 'Intense Peru - Página de contacto', url: 'intenseperu.com/contact' }
    ]
  },
  mobileShowcase: [
    {
      title: 'Home',
      mobile: '/images/projects/intense/Home-mobile.png'
    },
    {
      title: 'Header',
      mobile: '/images/projects/intense/Header-mobile.png'
    },
    {
      title: 'Destinations',
      mobile: '/images/projects/intense/destinations-mobile.png'
    },
    {
      title: 'Journeys',
      mobile: '/images/projects/intense/journeys-mobile.png'
    },
    {
      title: 'Itinerary',
      mobile: '/images/projects/intense/itinerary-mobile.png'
    },
    {
      title: 'Design Your Trip',
      mobile: '/images/projects/intense/DESIGNYOURTRIP-mobile.png'
    },
    {
      title: 'Blog',
      mobile: '/images/projects/intense/blog-mobile.png'
    }
  ]
};
---

<Layout title={`${project.title} | Caso de Estudio`} description={project.overview}>
  <Header />

  <main>
    <!-- Hero Section -->
    <section data-hero class="relative min-h-screen flex flex-col justify-end px-6 md:px-12 lg:px-24 pb-16 pt-32 overflow-hidden">
      <!-- Floating Elements -->
      <FloatingElements variant="hero" intensity="subtle" />

      <!-- Back link -->
      <a href="/work" class="reveal group inline-flex items-center gap-2 text-[var(--color-text-muted)] hover:text-[var(--color-primary)] transition-colors mb-12 relative z-10" data-delay="0">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 transition-transform duration-300 group-hover:-translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 16l-4-4m0 0l4-4m-4 4h18" />
        </svg>
        <span class="text-sm uppercase tracking-wider underline-grow">Volver a proyectos</span>
      </a>

      <div class="max-w-7xl relative z-10">
        <!-- Tags with stagger animation -->
        <div class="reveal flex flex-wrap gap-2 mb-6" data-delay="0.1">
          {project.tags.map((tag, index) => (
            <span class="tag hover-lift" style={`animation-delay: ${index * 0.05}s`}>{tag}</span>
          ))}
        </div>

        <!-- Title with split text animation -->
        <h1 class="reveal font-display text-5xl md:text-6xl lg:text-7xl xl:text-8xl font-semibold mb-6 leading-[1.1]" data-delay="0.2">
          <span class="inline-block">{project.title}</span>
        </h1>

        <!-- Subtitle with elegant animation -->
        <p class="reveal text-[var(--color-text-muted)] text-xl md:text-2xl max-w-3xl mb-12 leading-relaxed" data-delay="0.3">
          {project.subtitle}
        </p>

        <!-- Meta info with stagger grid -->
        <div class="reveal stagger-grid grid grid-cols-2 md:grid-cols-4 gap-8" data-delay="0.4">
          <div class="group">
            <p class="text-[var(--color-text-muted)] text-sm uppercase tracking-wider mb-2 transition-colors group-hover:text-[var(--color-primary)]">Cliente</p>
            <p class="font-medium text-lg">{project.client}</p>
          </div>
          <div class="group">
            <p class="text-[var(--color-text-muted)] text-sm uppercase tracking-wider mb-2 transition-colors group-hover:text-[var(--color-primary)]">Rol</p>
            <p class="font-medium text-lg">{project.role}</p>
          </div>
          <div class="group">
            <p class="text-[var(--color-text-muted)] text-sm uppercase tracking-wider mb-2 transition-colors group-hover:text-[var(--color-primary)]">Duración</p>
            <p class="font-medium text-lg">{project.duration}</p>
          </div>
          <div class="group">
            <p class="text-[var(--color-text-muted)] text-sm uppercase tracking-wider mb-2 transition-colors group-hover:text-[var(--color-primary)]">Año</p>
            <p class="font-medium text-lg">{project.year}</p>
          </div>
        </div>
      </div>

      <!-- Scroll indicator -->
      <div class="absolute bottom-8 left-1/2 -translate-x-1/2 reveal" data-delay="1">
        <div class="flex flex-col items-center gap-2">
          <span class="text-[var(--color-text-muted)] text-xs uppercase tracking-widest">Scroll</span>
          <div class="w-[1px] h-12 bg-[var(--color-border)] relative overflow-hidden">
            <div class="absolute top-0 left-0 w-full h-full bg-[var(--color-primary)] animate-scroll-line"></div>
          </div>
        </div>
      </div>
    </section>

    <!-- Hero Image with Parallax -->
    <section class="px-6 md:px-12 lg:px-24 py-8 md:py-12">
      <div class="max-w-[1800px] mx-auto">
        <div class="reveal rounded-2xl overflow-hidden shadow-2xl" data-delay="0.2">
          <img
            src="/images/projects/intense/heroIntense.png"
            alt={`${project.title} - Vista principal`}
            class="w-full aspect-[16/9] object-cover object-top"
            loading="eager"
            decoding="async"
            fetchpriority="high"
          />
        </div>
      </div>
    </section>

    <!-- Overview -->
    <section class="px-6 md:px-12 lg:px-24 py-24 border-t border-[var(--color-border)] relative overflow-hidden">
      <!-- Subtle background decoration -->
      <div class="absolute top-0 right-0 w-96 h-96 bg-[var(--color-secondary)]/5 rounded-full blur-3xl -translate-y-1/2 translate-x-1/2"></div>

      <div class="max-w-7xl mx-auto grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-24 relative z-10">
        <div class="lg:col-span-4">
          <p class="reveal text-[var(--color-text-muted)] text-sm uppercase tracking-[0.3em] mb-4 flex items-center gap-2" data-delay="0">
            <span class="w-8 h-[1px] bg-[var(--color-primary)]"></span>
            Resumen
          </p>
          <h2 class="reveal font-serif text-3xl md:text-4xl lg:text-5xl font-medium italic" data-delay="0.1">
            Sobre el proyecto
          </h2>
        </div>
        <div class="lg:col-span-8">
          <p class="reveal text-lg md:text-xl leading-relaxed text-[var(--color-text-muted)] mb-8" data-delay="0.2">
            {project.overview}
          </p>

          <!-- Tools used with hover effects -->
          <div class="reveal" data-delay="0.3">
            <p class="text-sm uppercase tracking-wider text-[var(--color-text-muted)] mb-4">Herramientas</p>
            <div class="flex flex-wrap gap-3">
              {project.tools.map((tool, index) => (
                <span class="tag hover-lift glow" style={`animation-delay: ${index * 0.1}s`}>{tool}</span>
              ))}
            </div>
          </div>
        </div>
      </div>

      <!-- Section divider -->
      <div class="section-divider max-w-7xl mx-auto mt-24"></div>
    </section>

    <!-- Challenge -->
    <section class="relative px-6 md:px-12 lg:px-24 py-24 bg-[var(--color-primary)] overflow-hidden">
      <!-- Decorative elements -->
      <div class="absolute inset-0 overflow-hidden pointer-events-none">
        <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[800px] h-[800px] rounded-full border border-[#FDF8F3]/5"></div>
        <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[600px] rounded-full border border-[#FDF8F3]/5"></div>
      </div>

      <div class="max-w-[1600px] mx-auto grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-24 relative z-10">
        <!-- Left side: Title and description -->
        <div>
          <p class="reveal text-[var(--color-secondary)] text-sm uppercase tracking-[0.3em] mb-4 flex items-center gap-3" data-delay="0">
            <span class="w-8 h-[1px] bg-[var(--color-secondary)]"></span>
            El reto
          </p>
          <h2 class="reveal font-serif text-3xl md:text-4xl lg:text-5xl font-medium text-[#FDF8F3] mb-8 italic" data-delay="0.1">
            Problema a resolver
          </h2>
          <p class="reveal text-lg md:text-xl leading-relaxed text-[#FDF8F3]/80" data-delay="0.2">
            {project.challenge}
          </p>
        </div>

        <!-- Right side: Goals as animated cards -->
        <div class="space-y-4">
          {project.goals.map((goal, index) => (
            <div
              class="reveal group flex items-center justify-between gap-6 px-6 py-5 bg-[#FDF8F3] rounded-full hover:bg-[var(--color-secondary)] transition-all duration-500 cursor-default hover-lift"
              data-delay={0.2 + index * 0.1}
            >
              <div class="flex items-center gap-4">
                <span class="flex-shrink-0 w-10 h-10 rounded-full bg-[var(--color-primary)]/10 text-[var(--color-primary)] flex items-center justify-center text-sm font-semibold group-hover:bg-[var(--color-primary)] group-hover:text-[#FDF8F3] transition-all duration-300 group-hover:scale-110">
                  {String(index + 1).padStart(2, '0')}
                </span>
                <span class="text-[var(--color-primary)] font-medium text-lg">{goal}</span>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Process -->
    <section class="px-6 md:px-12 lg:px-24 py-24 border-t border-[var(--color-border)] relative">
      <!-- Background decoration -->
      <div class="absolute bottom-0 left-0 w-72 h-72 bg-[var(--color-primary)]/5 rounded-full blur-3xl"></div>

      <div class="max-w-7xl mx-auto relative z-10">
        <div class="text-center mb-20">
          <p class="reveal text-[var(--color-text-muted)] text-sm uppercase tracking-[0.3em] mb-4 flex items-center justify-center gap-3" data-delay="0">
            <span class="w-8 h-[1px] bg-[var(--color-primary)]"></span>
            Mi proceso
            <span class="w-8 h-[1px] bg-[var(--color-primary)]"></span>
          </p>
          <h2 class="reveal font-serif text-3xl md:text-4xl lg:text-5xl font-medium italic" data-delay="0.1">
            De la investigación al diseño
          </h2>
          <p class="reveal text-[var(--color-text-muted)] text-lg mt-4 max-w-2xl mx-auto" data-delay="0.2">
            Un proceso completo de UX/UI: desde el kick-off y research hasta wireframes de todas las pantallas y diseño visual final.
          </p>
        </div>

        <!-- Process steps - alternating layout -->
        <div class="space-y-32">
          {project.process.map((step, index) => (
            <div class={`grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-24 items-center ${index % 2 === 1 ? 'lg:flex-row-reverse' : ''}`}>
              <div class={index % 2 === 1 ? 'lg:order-2' : ''}>
                <div class="reveal" data-delay="0">
                  <div class="inline-flex items-center gap-3 mb-4">
                    <span class="w-8 h-[1px] bg-[var(--color-primary)]"></span>
                    <span class="text-[var(--color-primary)] text-xs uppercase tracking-[0.3em]">{step.phase}</span>
                  </div>

                  <!-- Title -->
                  <div class="flex items-center gap-4 mb-6">
                    <h3 class="font-serif text-2xl md:text-3xl lg:text-4xl font-medium italic">
                      {step.title}
                    </h3>
                  </div>

                  <p class="text-[var(--color-text-muted)] text-lg leading-relaxed">
                    {step.description}
                  </p>
                </div>
              </div>
              <div class={index % 2 === 1 ? 'lg:order-1' : ''}>
                <div class="reveal rounded-2xl overflow-hidden" data-delay="0.2">
                  <img
                    src={step.image}
                    alt={step.title}
                    class="w-full aspect-[4/3] object-cover object-top"
                    loading="lazy"
                  />
                </div>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Highlights -->
    <section class="relative px-6 md:px-12 lg:px-24 py-24 bg-[var(--color-primary)] overflow-hidden">
      <!-- Decorative circles -->
      <div class="absolute inset-0 pointer-events-none overflow-hidden">
        <div class="absolute -top-20 -right-20 w-80 h-80 rounded-full border border-[#FDF8F3]/5"></div>
        <div class="absolute -bottom-40 -left-40 w-96 h-96 rounded-full border border-[#FDF8F3]/5"></div>
      </div>

      <div class="max-w-7xl mx-auto relative z-10">
        <div class="text-center mb-16">
          <p class="reveal text-[var(--color-bg)]/70 text-sm uppercase tracking-[0.3em] mb-4 flex items-center justify-center gap-3" data-delay="0">
            <span class="text-[var(--color-secondary)]">&#10038;</span>
            Destacados
            <span class="text-[var(--color-secondary)]">&#10038;</span>
          </p>
          <h2 class="reveal font-serif text-3xl md:text-4xl lg:text-5xl font-medium text-[var(--color-bg)] italic" data-delay="0.1">
            Soluciones clave
          </h2>
        </div>

        <div class="stagger-grid grid grid-cols-1 md:grid-cols-2 gap-6">
          {project.highlights.map((highlight, index) => (
            <div class="reveal group flex items-start gap-5 p-8 bg-[var(--color-bg)]/10 backdrop-blur-sm rounded-2xl border border-[var(--color-bg)]/10 hover:bg-[var(--color-bg)]/15 hover:border-[var(--color-secondary)]/30 transition-all duration-500" data-delay={0.1 + index * 0.1}>
              <div class="flex-shrink-0 w-12 h-12 rounded-full bg-[var(--color-secondary)]/20 flex items-center justify-center group-hover:scale-110 group-hover:bg-[var(--color-secondary)] transition-all duration-300">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-[var(--color-bg)]" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                </svg>
              </div>
              <p class="text-[var(--color-bg)] text-lg leading-relaxed">{highlight}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Desktop Showcase -->
    <DesktopShowcase
      title="Pantallas Desktop"
      subtitle="Diseño UI"
      sections={[
        {
          title: "Páginas Principales",
          pages: project.desktopShowcase.mainPages,
          columns: 2
        },
        {
          title: "Journeys e Itinerarios",
          pages: project.desktopShowcase.journeysPages,
          columns: 2
        },
        {
          title: "Blog y Contacto",
          pages: project.desktopShowcase.contentPages,
          columns: 2
        }
      ]}
    />

    <!-- Mobile Showcase -->
    <MobileShowcase
      title="Experiencia Mobile"
      subtitle="Responsive Design"
      screens={project.mobileShowcase}
    />

    <section class="relative px-6 md:px-12 lg:px-24 py-24 border-t border-[var(--color-border)] overflow-hidden">
      <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[600px] rounded-full bg-[var(--color-secondary)]/5 blur-3xl pointer-events-none"></div>

      <div class="max-w-3xl mx-auto text-center relative z-10">
        <div class="reveal mb-10" data-delay="0">
          <p class="text-[var(--color-text-muted)] text-sm uppercase tracking-[0.3em] flex items-center justify-center gap-2">
            <span class="w-8 h-[1px] bg-[var(--color-primary)]"></span>
            Testimonio
            <span class="w-8 h-[1px] bg-[var(--color-primary)]"></span>
          </p>
        </div>

        <div class="reveal mb-6 flex justify-center" data-delay="0.1">
          <span class="inline-flex items-center justify-center w-12 h-12 rounded-full bg-[var(--color-primary)]/10">
            <svg class="w-5 h-5 text-[var(--color-primary)]" fill="currentColor" viewBox="0 0 24 24">
              <path d="M14.017 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151c-2.432.917-3.995 3.638-3.995 5.849h4v10h-9.983zm-14.017 0v-7.391c0-5.704 3.748-9.57 9-10.609l.996 2.151c-2.433.917-3.996 3.638-3.996 5.849h3.983v10h-9.983z"/>
            </svg>
          </span>
        </div>

        <blockquote class="reveal font-serif text-xl md:text-2xl font-medium leading-relaxed mb-10 italic text-[var(--color-text-muted)]" data-delay="0.2">
          "{project.testimonial.quote}"
        </blockquote>

        <div class="reveal flex flex-col items-center gap-3" data-delay="0.3">
          <div class="w-10 h-[1px] bg-[var(--color-border)] mx-auto"></div>
          <p class="font-medium text-base text-[var(--color-text)]">{project.testimonial.author}</p>
          <p class="text-[var(--color-text-muted)] text-sm">{project.testimonial.role}</p>
          <a
            href={project.testimonial.authorUrl}
            target="_blank"
            rel="noopener noreferrer"
            aria-label="Ver perfil en LinkedIn"
            class="inline-flex items-center justify-center mt-1 w-8 h-8 rounded-full border border-[var(--color-border)] text-[var(--color-text-muted)] hover:border-[var(--color-primary)]/40 hover:text-[var(--color-primary)] transition-all duration-300"
          >
            <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 24 24">
              <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
            </svg>
          </a>
        </div>
      </div>
    </section>

    <section class="border-t border-[var(--color-border)] relative overflow-hidden">
      <a href={`/work/${project.nextProject.slug}`} class="group block px-6 md:px-12 lg:px-24 py-24 transition-colors duration-500 hover:bg-[var(--color-secondary)]">
        <div class="absolute inset-0 bg-[var(--color-secondary)] transform scale-y-0 origin-bottom transition-transform duration-700 ease-out group-hover:scale-y-100 -z-10"></div>

        <div class="max-w-7xl mx-auto flex flex-col md:flex-row md:items-center md:justify-between gap-8 relative z-10">
          <div>
            <p class="text-[var(--color-text-muted)] text-sm uppercase tracking-[0.3em] mb-4 flex items-center gap-2 group-hover:text-[var(--color-primary)]/70 transition-colors duration-500">
              <span class="w-8 h-[1px] bg-current"></span>
              Siguiente proyecto
            </p>
            <h3 class="font-serif text-3xl md:text-4xl lg:text-5xl xl:text-6xl font-medium italic group-hover:text-[var(--color-primary)] transition-colors duration-500">
              {project.nextProject.title}
            </h3>
          </div>
          <div class="flex-shrink-0">
            <div class="w-20 h-20 rounded-full border-2 border-[var(--color-border)] inline-flex items-center justify-center group-hover:border-[var(--color-primary)] group-hover:bg-[var(--color-primary)] transition-all duration-500 group-hover:scale-110 leading-none">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8 flex-none transition-all duration-500 group-hover:translate-x-2 group-hover:text-[#FDF8F3]" fill="none" viewBox="0 0 24 24" stroke="currentColor" style="display:block">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
              </svg>
            </div>
          </div>
        </div>
      </a>
    </section>
  </main>

  <Footer />
</Layout>
