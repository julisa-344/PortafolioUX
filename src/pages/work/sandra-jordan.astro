---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import DesktopShowcase from '../../components/DesktopShowcase.astro';
import MobileShowcase from '../../components/MobileShowcase.astro';
import FloatingElements from '../../components/FloatingElements.astro';

// Datos del proyecto Sandra Jordan
const project = {
  title: 'Sandra Jordan Prima Alpaca',
  subtitle: 'Rediseño Web de Lujo para Marca de Textiles de Alpaca',
  year: '2025',
  client: 'Sandra Jordan @ Nerd',
  role: 'UI Designer',
  duration: '+4 meses',
  tools: ['Figma', 'Claude', 'ChatGPT', 'Gemini', 'Pencil'],
  tags: ['UI Design', 'Luxury Brand', 'Visual Design', 'Rediseño'],
  overview: 'Rediseño web de lujo para Sandra Jordan Prima Alpaca, marca premium de textiles de alpaca con showrooms propios. El sitio no vende productos online — permite solicitar muestras de tela y dirige a los usuarios a sus showrooms, donde ocurre la venta real. Me integré a un proyecto con avance previo, continuando y ajustando lo existente mientras diseñaba nuevas pantallas y flujos. El entregable incluyó el diseño completo del sitio, handoff a desarrolladores y QA del diseño implementado.',
  challenge: 'Entrar a un proyecto avanzado y entender qué se había hecho, por qué, y cómo continuarlo sin romper la coherencia visual. El cliente buscaba comunicarse como una marca de lujo — algo que su web anterior no lograba — y a la vez guiar al usuario hacia sus showrooms y la solicitud de muestras, que es donde ocurre la venta real. El reto fue elevar la experiencia visual manteniendo la línea gráfica establecida y sin que el cambio de mano se notara.',
  goals: [
    'Mantener la coherencia con el diseño previo y la línea gráfica establecida',
    'Diseñar y ajustar pantallas para completar el sitio',
    'Elevar la experiencia visual para comunicar lujo y exclusividad',
    'Dirigir al usuario hacia showrooms y solicitud de muestras',
    'Hacer el handoff a desarrolladores y QA del diseño implementado'
  ],
  process: [
    {
      phase: 'Research',
      title: 'Entender la marca y el mercado',
      description: 'Antes de diseñar analicé los competidores de Sandra Jordan: marcas de lujo como Loro Piana, Brunello Cucinelli y otras referencias premium de textiles. También revisé el trabajo existente para entender la línea gráfica establecida, el objetivo de la web y qué transmitir al usuario. La marca quería dejar atrás una web que no los representaba y comunicarse como lo que son: una marca de lujo.',
      image: '/images/projects/sandra-jordan/beanchmark.webp'
    },
    {
      phase: 'UI Design',
      title: 'Diseño y ajustes de pantallas',
      description: 'Continué y ajusté el trabajo existente del diseñador anterior mientras diseñaba todas las pantallas y flujos faltantes. El objetivo era que el resultado final se leyera como un sistema cohesivo de principio a fin, comunicando la exclusividad que la marca buscaba transmitir y guiando al usuario hacia showrooms y solicitud de muestras.',
      image: '/images/projects/sandra-jordan/portadacard.webp'
    },
    {
      phase: 'Handoff & QA',
      title: 'Entrega y revisión con desarrolladores',
      description: 'Una vez completado el diseño, hice el handoff al equipo de desarrollo y participé en el QA del diseño implementado, asegurando que la fidelidad visual se mantuviera en el producto final. Este proceso también estuvo presente en la mayoría de mis otros proyectos.',
      image: '/images/projects/sandra-jordan/desarrollo.webp'
    }
  ],
  highlights: [
    'Integración a un proyecto avanzado continuando y ajustando lo existente',
    'Diseño que eleva la identidad de una marca de lujo',
    'Flujos que dirigen al usuario a showrooms y solicitud de muestras',
    'Handoff a desarrolladores y QA del diseño implementado'
  ],
  testimonial: null as null | { quote: string; author: string; role: string },
  nextProject: {
    slug: 'comsatel',
    title: 'Comsatel'
  },
  desktopShowcase: {
    mainPages: [
      { src: '/images/projects/sandra-jordan/homemain.webp', label: 'Home', alt: 'Sandra Jordan - Página principal', url: 'sandrajordan.com' },
      { src: '/images/projects/sandra-jordan/productpage.webp', label: 'Product Page', alt: 'Sandra Jordan - Página de producto', url: 'sandrajordan.com/product' },
      { src: '/images/projects/sandra-jordan/textiles.webp', label: 'Textiles', alt: 'Sandra Jordan - Colección Textiles', url: 'sandrajordan.com/textiles' },
      { src: '/images/projects/sandra-jordan/showroom.webp', label: 'Showroom', alt: 'Sandra Jordan - Showroom', url: 'sandrajordan.com/showroom' }
    ],
    bespokePages: [
      { src: '/images/projects/sandra-jordan/bespokeprogram.webp', label: 'Bespoke Program', alt: 'Sandra Jordan - Programa Bespoke', url: 'sandrajordan.com/bespoke' },
      { src: '/images/projects/sandra-jordan/bespokerugs.webp', label: 'Bespoke Rugs', alt: 'Sandra Jordan - Alfombras Bespoke', url: 'sandrajordan.com/bespoke/rugs' },
      { src: '/images/projects/sandra-jordan/bespoketrhows.webp', label: 'Bespoke Throws', alt: 'Sandra Jordan - Mantas Bespoke', url: 'sandrajordan.com/bespoke/throws' }
    ],
    accountPages: [
      { src: '/images/projects/sandra-jordan/myaccountmydetails.webp', label: 'Account Details', alt: 'Sandra Jordan - Detalles de cuenta', url: 'sandrajordan.com/account' },
      { src: '/images/projects/sandra-jordan/myaccountmyfavorites1.webp', label: 'Favorites', alt: 'Sandra Jordan - Favoritos', url: 'sandrajordan.com/account/favorites' },
      { src: '/images/projects/sandra-jordan/myaccountmyfavorites4.webp', label: 'Orders', alt: 'Sandra Jordan - Pedidos', url: 'sandrajordan.com/account/orders' },
      { src: '/images/projects/sandra-jordan/myaccountmyorders.webp', label: 'My Orders', alt: 'Sandra Jordan - Mis pedidos', url: 'sandrajordan.com/account/my-orders' }
    ],
    contentPages: [
      { src: '/images/projects/sandra-jordan/about.webp', label: 'About', alt: 'Sandra Jordan - About', url: 'sandrajordan.com/about' },
      { src: '/images/projects/sandra-jordan/press.webp', label: 'Press', alt: 'Sandra Jordan - Press', url: 'sandrajordan.com/press' },
      { src: '/images/projects/sandra-jordan/inspiration.webp', label: 'Inspiration', alt: 'Sandra Jordan - Inspiración', url: 'sandrajordan.com/inspiration' }
    ]
  },
  mobileShowcase: [
    {
      title: 'Home',
      mobile: '/images/projects/sandra-jordan/homemobile.webp',
      description: 'Página principal con navegación elegante y acceso a colecciones'
    },
    {
      title: 'Bespoke Program',
      mobile: '/images/projects/sandra-jordan/bespokeprogrammobile.webp',
      description: 'Programa de personalización premium con navegación intuitiva'
    },
    {
      title: 'Bespoke Rugs',
      mobile: '/images/projects/sandra-jordan/bespokerugsmobile.webp',
      description: 'Selección de alfombras personalizadas con materiales premium'
    },
    {
      title: 'Bespoke Throws',
      mobile: '/images/projects/sandra-jordan/bespoketrhowsmobile.webp',
      description: 'Mantas bespoke con fibra de alpaca de alta calidad'
    },
    {
      title: 'My Moodboards',
      mobile: '/images/projects/sandra-jordan/myaccountfavoritesmobile1.webp',
      description: 'Gestión de productos favoritos con acceso rápido'
    },
    {
      title: 'My Collection',
      mobile: '/images/projects/sandra-jordan/myaccountdetailsmobile2.webp',
      description: 'Panel de usuario con información organizada'
    }
  ]
};
---

<Layout title={`${project.title} | Caso de Estudio`} description={project.overview}>
  <Header />

  <main>
    <section class="relative min-h-screen flex flex-col justify-end px-6 md:px-12 lg:px-24 pb-24 pt-32 overflow-hidden">
      <FloatingElements variant="hero" intensity="subtle" />

      <a href="/work" class="reveal group inline-flex items-center gap-2 text-[var(--color-text-muted)] hover:text-[var(--color-primary)] transition-colors mb-12 relative z-10" data-delay="0">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 transition-transform duration-300 group-hover:-translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 16l-4-4m0 0l4-4m-4 4h18" />
        </svg>
        <span class="text-sm uppercase tracking-wider underline-grow">Volver a proyectos</span>
      </a>

      <div class="max-w-7xl relative z-10">
        <div class="reveal flex flex-wrap gap-2 mb-6" data-delay="0.1">
          {project.tags.map((tag, index) => (
            <span class="tag hover-lift" style={`animation-delay: ${index * 0.05}s`}>{tag}</span>
          ))}
        </div>

        <h1 class="reveal font-display text-5xl md:text-6xl lg:text-7xl xl:text-8xl font-semibold mb-6 leading-[1.1]" data-delay="0.2">
          <span class="inline-block">{project.title}</span>
        </h1>

        <p class="reveal text-[var(--color-text-muted)] text-xl md:text-2xl max-w-3xl mb-12 leading-relaxed" data-delay="0.3">
          {project.subtitle}
        </p>

        <div class="reveal stagger-grid grid grid-cols-2 md:grid-cols-4 gap-8" data-delay="0.4">
          <div class="group">
            <p class="text-[var(--color-text-muted)] text-sm uppercase tracking-wider mb-2 transition-colors group-hover:text-[var(--color-primary)]">Cliente</p>
            <p class="font-medium text-lg">{project.client}</p>
          </div>
          <div class="group">
            <p class="text-[var(--color-text-muted)] text-sm uppercase tracking-wider mb-2 transition-colors group-hover:text-[var(--color-primary)]">Rol</p>
            <p class="font-medium text-lg">{project.role}</p>
          </div>
          <div class="group">
            <p class="text-[var(--color-text-muted)] text-sm uppercase tracking-wider mb-2 transition-colors group-hover:text-[var(--color-primary)]">Duración</p>
            <p class="font-medium text-lg">{project.duration}</p>
          </div>
          <div class="group">
            <p class="text-[var(--color-text-muted)] text-sm uppercase tracking-wider mb-2 transition-colors group-hover:text-[var(--color-primary)]">Año</p>
            <p class="font-medium text-lg">{project.year}</p>
          </div>
        </div>
      </div>

      <div class="absolute bottom-8 left-1/2 -translate-x-1/2 reveal" data-delay="1">
        <div class="flex flex-col items-center gap-2">
          <span class="text-[var(--color-text-muted)] text-xs uppercase tracking-widest">Scroll</span>
          <div class="w-[1px] h-12 bg-[var(--color-border)] relative overflow-hidden">
            <div class="absolute top-0 left-0 w-full h-full bg-[var(--color-primary)] animate-scroll-line"></div>
          </div>
        </div>
      </div>
    </section>

    <section class="px-6 md:px-12 lg:px-24 py-12 md:py-16">
      <div class="max-w-[1800px] mx-auto">
        <div class="reveal rounded-2xl overflow-hidden shadow-2xl" data-delay="0.2">
          <img
            src="/images/projects/sandra-jordan/hero.webp"
            alt={`${project.title} - Vista principal`}
            class="w-full aspect-[16/9] object-cover"
            loading="eager"
            decoding="async"
            fetchpriority="high"
          />
        </div>
      </div>
    </section>

    <section class="px-6 md:px-12 lg:px-24 py-24 border-t border-[var(--color-border)] relative overflow-hidden">
      <div class="absolute top-0 right-0 w-96 h-96 bg-[var(--color-secondary)]/5 rounded-full blur-3xl -translate-y-1/2 translate-x-1/2"></div>

      <div class="max-w-7xl mx-auto grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-24 relative z-10">
        <div class="lg:col-span-4">
          <p class="reveal text-[var(--color-text-muted)] text-sm uppercase tracking-[0.3em] mb-4 flex items-center gap-2" data-delay="0">
            <span class="w-8 h-[1px] bg-[var(--color-primary)]"></span>
            Resumen
          </p>
          <h2 class="reveal font-serif text-3xl md:text-4xl lg:text-5xl font-medium italic" data-delay="0.1">
            Sobre el proyecto
          </h2>
        </div>
        <div class="lg:col-span-8">
          <p class="reveal text-lg md:text-xl leading-relaxed text-[var(--color-text-muted)] mb-8" data-delay="0.2">
            {project.overview}
          </p>

          <div class="reveal" data-delay="0.3">
            <p class="text-sm uppercase tracking-wider text-[var(--color-text-muted)] mb-4">Herramientas</p>
            <div class="flex flex-wrap gap-3">
              {project.tools.map((tool, index) => (
                <span class="tag hover-lift glow" style={`animation-delay: ${index * 0.1}s`}>{tool}</span>
              ))}
            </div>
          </div>
        </div>
      </div>

      <div class="section-divider max-w-7xl mx-auto mt-24"></div>
    </section>

    <section class="relative px-6 md:px-12 lg:px-24 py-24 bg-[var(--color-primary)] overflow-hidden">
      <div class="absolute inset-0 overflow-hidden pointer-events-none">
        <img src="/mariposa.png" alt="" class="absolute top-10 right-10 w-24 opacity-10 float-slow" />
        <img src="/mariposa2.png" alt="" class="absolute bottom-20 left-20 w-16 opacity-5 float-delayed" />
        <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[800px] h-[800px] rounded-full border border-[#FDF8F3]/5"></div>
        <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[600px] rounded-full border border-[#FDF8F3]/5"></div>
      </div>

      <div class="max-w-[1600px] mx-auto grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-24 relative z-10">
        <div>
          <p class="reveal text-[var(--color-secondary)] text-sm uppercase tracking-[0.3em] mb-4 flex items-center gap-3" data-delay="0">
            <span class="w-8 h-[1px] bg-[var(--color-secondary)]"></span>
            El reto
          </p>
          <h2 class="reveal font-serif text-3xl md:text-4xl lg:text-5xl font-medium text-[#FDF8F3] mb-8 italic" data-delay="0.1">
            Problema a resolver
          </h2>
          <p class="reveal text-lg md:text-xl leading-relaxed text-[#FDF8F3]/80" data-delay="0.2">
            {project.challenge}
          </p>
        </div>

        <div class="space-y-4">
          {project.goals.map((goal, index) => (
            <div
              class="reveal group flex items-center justify-between gap-6 px-6 py-5 bg-[#FDF8F3] rounded-full hover:bg-[var(--color-secondary)] transition-all duration-500 cursor-default hover-lift"
              data-delay={0.2 + index * 0.1}
            >
              <div class="flex items-center gap-4">
                <span class="flex-shrink-0 w-10 h-10 rounded-full bg-[var(--color-primary)]/10 text-[var(--color-primary)] flex items-center justify-center text-sm font-semibold group-hover:bg-[var(--color-primary)] group-hover:text-[#FDF8F3] transition-all duration-300 group-hover:scale-110">
                  {String(index + 1).padStart(2, '0')}
                </span>
                <span class="text-[var(--color-primary)] font-medium text-lg">{goal}</span>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <section class="px-6 md:px-12 lg:px-24 py-24 border-t border-[var(--color-border)] relative">
      <div class="absolute bottom-0 left-0 w-72 h-72 bg-[var(--color-primary)]/5 rounded-full blur-3xl"></div>

      <div class="max-w-7xl mx-auto relative z-10">
        <div class="text-center mb-20">
          <p class="reveal text-[var(--color-text-muted)] text-sm uppercase tracking-[0.3em] mb-4 flex items-center justify-center gap-3" data-delay="0">
            <span class="w-8 h-[1px] bg-[var(--color-primary)]"></span>
            Mi proceso
            <span class="w-8 h-[1px] bg-[var(--color-primary)]"></span>
          </p>
          <h2 class="reveal font-serif text-3xl md:text-4xl lg:text-5xl font-medium italic" data-delay="0.1">
            Diseñando experiencias de lujo
          </h2>
          <p class="reveal text-[var(--color-text-muted)] text-lg mt-4 max-w-2xl mx-auto" data-delay="0.2">
            Desde entender la marca y el trabajo previo hasta diseñar cada pantalla y acompañar el handoff, garantizando coherencia visual de principio a fin.
          </p>
        </div>

        <div class="space-y-32">
          {project.process.map((step, index) => (
            <div class={`grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-24 items-center ${index % 2 === 1 ? 'lg:flex-row-reverse' : ''}`}>
              <div class={index % 2 === 1 ? 'lg:order-2' : ''}>
                <div class="reveal" data-delay="0">
                  <div class="inline-flex items-center gap-3 mb-4">
                    <span class="w-8 h-[1px] bg-[var(--color-primary)]"></span>
                    <span class="text-[var(--color-primary)] text-xs uppercase tracking-[0.3em]">{step.phase}</span>
                  </div>

                  <div class="flex items-center gap-4 mb-6">
                    <h3 class="font-serif text-2xl md:text-3xl lg:text-4xl font-medium italic">
                      {step.title}
                    </h3>
                  </div>

                  <p class="text-[var(--color-text-muted)] text-lg leading-relaxed">
                    {step.description}
                  </p>
                </div>
              </div>
              <div class={index % 2 === 1 ? 'lg:order-1' : ''}>
                <div class="reveal rounded-2xl overflow-hidden" data-delay="0.2">
                  <img
                    src={step.image}
                    alt={step.title}
                    class="w-full aspect-[4/3] object-cover"
                  />
                </div>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <section class="relative px-6 md:px-12 lg:px-24 py-24 bg-[var(--color-primary)] overflow-hidden">
      <div class="absolute inset-0 pointer-events-none overflow-hidden">
        <div class="absolute -top-20 -right-20 w-80 h-80 rounded-full border border-[#FDF8F3]/5"></div>
        <div class="absolute -bottom-40 -left-40 w-96 h-96 rounded-full border border-[#FDF8F3]/5"></div>
      </div>

      <div class="max-w-7xl mx-auto relative z-10">
        <div class="text-center mb-16">
          <p class="reveal text-[var(--color-bg)]/70 text-sm uppercase tracking-[0.3em] mb-4 flex items-center justify-center gap-3" data-delay="0">
            <span class="text-[var(--color-secondary)]">&#10038;</span>
            Destacados
            <span class="text-[var(--color-secondary)]">&#10038;</span>
          </p>
          <h2 class="reveal font-serif text-3xl md:text-4xl lg:text-5xl font-medium text-[var(--color-bg)] italic" data-delay="0.1">
            Soluciones clave
          </h2>
        </div>

        <div class="stagger-grid grid grid-cols-1 md:grid-cols-2 gap-6">
          {project.highlights.map((highlight, index) => (
            <div class="reveal group flex items-start gap-5 p-8 bg-[var(--color-bg)]/10 backdrop-blur-sm rounded-2xl border border-[var(--color-bg)]/10 hover:bg-[var(--color-bg)]/15 hover:border-[var(--color-secondary)]/30 transition-all duration-500" data-delay={0.1 + index * 0.1}>
              <div class="flex-shrink-0 w-12 h-12 rounded-full bg-[var(--color-secondary)]/20 flex items-center justify-center group-hover:scale-110 group-hover:bg-[var(--color-secondary)] transition-all duration-300">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-[var(--color-bg)]" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                </svg>
              </div>
              <p class="text-[var(--color-bg)] text-lg leading-relaxed">{highlight}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <DesktopShowcase
      title="Pantallas Desktop"
      subtitle="Diseño UI"
      sections={[
        {
          title: "Páginas Principales",
          pages: project.desktopShowcase.mainPages,
          columns: 2
        },
        {
          title: "Programa Bespoke",
          pages: project.desktopShowcase.bespokePages,
          columns: 3
        },
        {
          title: "Área de Usuario",
          pages: project.desktopShowcase.accountPages,
          columns: 4
        },
        {
          title: "Páginas de Contenido",
          pages: project.desktopShowcase.contentPages,
          columns: 3
        }
      ]}
    />

    <MobileShowcase
      title="Experiencia Mobile"
      subtitle="Responsive Design"
      description="Adaptación responsive manteniendo la experiencia premium en dispositivos móviles"
      screens={project.mobileShowcase}
    />

    {project.testimonial && (
      <section class="relative px-6 md:px-12 lg:px-24 py-32 border-t border-[var(--color-border)] overflow-hidden">
        <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[600px] rounded-full bg-[var(--color-secondary)]/5 blur-3xl"></div>
        <img src="/mariposa3.png" alt="" class="absolute top-20 right-20 w-20 opacity-10 float" />

        <div class="max-w-4xl mx-auto text-center relative z-10">
          <div class="reveal" data-delay="0">
            <span class="inline-flex items-center justify-center w-16 h-16 rounded-full bg-[var(--color-primary)]/10 mb-8">
              <svg class="w-8 h-8 text-[var(--color-primary)]" fill="currentColor" viewBox="0 0 24 24">
                <path d="M14.017 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151c-2.432.917-3.995 3.638-3.995 5.849h4v10h-9.983zm-14.017 0v-7.391c0-5.704 3.748-9.57 9-10.609l.996 2.151c-2.433.917-3.996 3.638-3.996 5.849h3.983v10h-9.983z"/>
              </svg>
            </span>
          </div>
          <blockquote class="reveal font-serif text-2xl md:text-3xl lg:text-4xl font-medium leading-relaxed mb-10 italic text-[var(--color-text)]" data-delay="0.1">
            "{project.testimonial.quote}"
          </blockquote>
          <div class="reveal" data-delay="0.2">
            <div class="inline-flex items-center gap-4">
              <div class="w-12 h-[1px] bg-[var(--color-border)]"></div>
              <div>
                <p class="font-medium text-lg">{project.testimonial.author}</p>
                <p class="text-[var(--color-text-muted)] text-sm">{project.testimonial.role}</p>
              </div>
              <div class="w-12 h-[1px] bg-[var(--color-border)]"></div>
            </div>
          </div>
        </div>
      </section>
    )}

    <section class="border-t border-[var(--color-border)] relative overflow-hidden">
      <a href={`/work/${project.nextProject.slug}`} class="group block px-6 md:px-12 lg:px-24 py-24 transition-colors duration-500 hover:bg-[var(--color-secondary)]">
        <div class="absolute inset-0 bg-[var(--color-secondary)] transform scale-y-0 origin-bottom transition-transform duration-700 ease-out group-hover:scale-y-100 -z-10"></div>

        <div class="max-w-7xl mx-auto flex flex-col md:flex-row md:items-center md:justify-between gap-8 relative z-10">
          <div>
