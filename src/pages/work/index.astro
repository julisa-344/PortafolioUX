---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import ProjectCard from '../../components/ProjectCard.astro';

// Todos los proyectos
const allProjects = [
  {
    slug: 'intense',
    title: 'Intense Viajes',
    category: 'Rediseño Web para Agencia de Viajes',
    description: 'Proyecto desde cero: kick-off, benchmark, sitemap, wireframes de todas las pantallas y UI Design. "Design your Trip" como eje central para una agencia de viajes boutique de lujo.',
    tags: ['UX Research', 'Wireframes', 'UI Design'],
    thumbnail: '/images/projects/intense/portadaCard.png',
    year: '2025',
    featured: true,
  },
  {
    slug: 'sandra-jordan',
    title: 'Sandra Jordan Prima Alpaca',
    category: 'Rediseño Web de Lujo',
    description: 'Rediseño web premium para marca de textiles de alpaca con showrooms propios. Pantallas completas, ajustes al diseño previo, handoff a devs y QA.',
    tags: ['UI Design', 'Luxury Brand', 'Visual Design'],
    thumbnail: '/images/projects/sandra-jordan/portadacard.webp',
    year: '2025',
    featured: true,
  },
  {
    slug: 'comsatel',
    title: 'Comsatel',
    category: 'Rediseño Web Multi-país',
    description: 'Rediseño web para empresa de rastreo GPS vehicular con presencia en Perú, Colombia y Bolivia. Arquitectura compleja, mega menú y flujo de cotización.',
    tags: ['UX Research', 'UI Design', 'Multi-país'],
    thumbnail: '/images/projects/comsatel/portadacard.webp',
    year: '2025',
    featured: true,
  },
  {
    slug: 'bitdefender',
    title: 'Bitdefender',
    category: 'UX Research',
    description: 'Investigación UX completa para rediseño con migración de portafolio. Benchmark, sitemap y wireframes para dos segmentos: B2C y B2B.',
    tags: ['UX Research', 'Benchmark', 'Wireframes'],
    thumbnail: '/images/projects/bitdefender/portadaCard.png',
    year: '2026',
    featured: true,
  },
  {
    slug: 'xplora',
    title: 'Xplora',
    category: 'Rediseño Web + Desarrollo',
    description: 'Rediseño de plataforma de cafeterías en Lima: research, perfilado de usuarios, nueva arquitectura de filtros e implementación directa en el repositorio.',
    tags: ['UX Research', 'UI Design', 'Frontend Dev'],
    thumbnail: '/images/projects/xplora/portadaCard.png',
    year: '2025',
    featured: true,
  },
];
---

<Layout title="Proyectos | Julisa - UX/UI Designer & Developer" description="Portfolio de proyectos de diseño UX/UI y desarrollo frontend. Casos de estudio de rediseño web, e-commerce y plataformas digitales.">
  <Header />
  
  <main>
    <!-- Hero Section -->
    <section class="min-h-[60vh] flex flex-col justify-end px-6 md:px-12 lg:px-24 pb-16 pt-32">
      <div class="max-w-[1600px] mx-auto w-full">
        <p class="reveal text-[var(--color-text-muted)] text-sm uppercase tracking-[0.3em] mb-4" data-delay="0">
          Portfolio
        </p>
        <h1 class="reveal font-display text-4xl md:text-5xl lg:text-6xl xl:text-7xl font-semibold mb-6" data-delay="0.1">
          Proyectos Seleccionados
        </h1>
        <p class="reveal text-[var(--color-text-muted)] text-lg md:text-xl max-w-2xl" data-delay="0.2">
          Una selección de proyectos donde he aplicado mi enfoque integral: 
          desde la investigación de usuarios hasta la implementación en código.
        </p>
      </div>
    </section>

    <!-- Projects Grid -->
    <section class="px-6 md:px-12 lg:px-24 pb-24">
      <div class="max-w-[1600px] mx-auto">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6 md:gap-8">
          {allProjects.map((project, index) => (
            <div class="reveal" data-delay={0.1 + index * 0.1}>
              <ProjectCard project={project} index={index} />
            </div>
          ))}
        </div>
      </div>
    </section>
  </main>

  <Footer />
</Layout>
