---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import MarqueeRibbon from '../components/MarqueeRibbon.astro';

// Skills organized by category
const skills = [
  {
    name: 'UX Research',
    items: ['Benchmark Analysis', 'User Interviews', 'Information Architecture', 'Sitemap', 'User Flows', 'Wireframes', 'Prototyping', 'Usability Testing'],
  },
  {
    name: 'UI Design',
    items: ['Design Systems', 'Visual Design', 'Responsive Design', 'Interaction Design', 'Figma', 'Adobe XD'],
  },
  {
    name: 'Development',
    items: ['React', 'Next.js', 'Vue.js', 'HTML/CSS', 'JavaScript', 'TypeScript', 'Tailwind CSS'],
  },
  {
    name: 'Soft Skills',
    items: ['Client Presentations', 'Stakeholder Management', 'Problem Solving', 'Team Collaboration', 'Project Planning', 'Design Thinking'],
  },
];

// Experience/trajectory
const experience = [
  {
    role: 'UX/UI Designer & Frontend Developer',
    company: 'Calcomaniacos',
    type: 'Proyecto end-to-end',
    period: '2023 – Dic 2025',
    skills: ['UX Research', 'UI Design', 'Next.js', 'Figma', 'Illustrator', 'GitHub'],
    description: 'Proyecto end-to-end: investigación de usuarios, diseño de interfaz e implementación frontend en colaboración directa con el equipo backend. Diseño del sistema visual completo en Figma e Illustrator, maquetación con Next.js e integración mediante GitHub.',
  },
  {
    role: 'Frontend Developer',
    company: 'CasaMarket',
    type: 'Full-time · Híbrido',
    period: 'Oct 2023 – Dic 2023',
    location: 'Lima, Perú',
    skills: ['HTML', 'React.js', 'CSS', 'JavaScript', 'Vue.js', 'Git'],
    description: 'Desempeñé los roles de diseñadora de interfaces, maquetadora y desarrolladora front-end. Implementé varios servicios en sus páginas, además de dar mantenimiento a los existentes y desarrollar nuevas funcionalidades.',
  },
  {
    role: 'Diseñadora UX / UI',
    company: 'NERD | Agencia',
    type: 'Full-time · Híbrido',
    period: 'Sep 2025 – Presente',
    skills: ['User Experience (UX)', 'Design Systems','UI Design', 'Figma'],
    description: 'Diseño de experiencias de usuario e interfaces para proyectos de clientes de la agencia. Trabajo en estrecha colaboración con el equipo de desarrollo para llevar los diseños a producción con precisión y calidad.',
  },
];
---

<Layout title="Sobre Mí | Julisa - UX/UI Designer & Developer" description="Conoce más sobre mi trayectoria como UX/UI Designer y Developer. Habilidades, experiencia y proceso de trabajo.">
  <Header />

  <main>

    <!-- ── HERO — full-width tipográfico ──────────────────────── -->
    <section class="about-hero px-6 md:px-12 lg:px-24 bg-[var(--color-primary)]"
             data-hero
             data-dark-header
             style="min-height:100svh; display:flex; flex-direction:column; justify-content:space-between;">
      <div class="max-w-[1600px] mx-auto w-full" style="display:flex; flex-direction:column; flex:1; justify-content:space-between;">

        <!-- TOP: pretitle + grid (título izq · datos der) -->
        <div class="pt-36">
          <!-- Pretitle -->
          <p class="about-hero-item flex items-center gap-3 text-[#FDF8F3]/50 text-xs uppercase tracking-[0.32em] mb-8" style="animation-delay:0.1s">
            <span class="w-7 h-[1px] bg-[#FDF8F3]/40"></span>
            Sobre mí
          </p>

          <!-- Grid 2 col: título izq · datos der (solo Rol + Ubicación junto al título) -->
          <div class="grid grid-cols-1 lg:grid-cols-[1fr_auto] gap-8 lg:gap-16 items-end">

            <!-- Título grande -->
            <h1 class="about-hero-item font-display font-semibold leading-[0.95] tracking-tight text-[#FDF8F3]"
                style="font-size: clamp(3rem, 7.5vw, 8rem); animation-delay:0.25s">
              Diseño lo que<br/>
              <em class="font-serif font-medium italic" style="color: rgba(253,248,243,0.6); font-size: 1.08em; letter-spacing: 0; text-transform: none;">conecta</em>
              y construyo<br/>lo que
              <em class="font-serif font-medium italic" style="color: rgba(253,248,243,0.6); font-size: 1.08em; letter-spacing: 0; text-transform: none;">funciona.</em>
            </h1>

          </div><!-- /grid título -->
        </div><!-- /TOP -->

        <!-- BOTTOM: divisor + los 3 datos juntos pegados al borde inferior -->
        <div class="pb-12">
          <!-- Divisor crema/opaco -->
          <div class="about-hero-item h-[1px] w-full bg-[#FDF8F3]/20 mb-10" style="animation-delay:0.4s"></div>

          <!-- Fila de 3 columnas: Rol · Ubicación · Disponibilidad -->
          <div class="about-hero-item grid grid-cols-1 md:grid-cols-3 gap-y-8" style="animation-delay:0.55s">
            <div class="md:border-r border-[#FDF8F3]/15 md:pr-8">
              <p class="text-[#FDF8F3]/45 text-[0.6rem] uppercase tracking-[0.3em] mb-2">Rol</p>
              <p class="font-display font-semibold text-[#FDF8F3] text-sm leading-snug">UX/UI Designer &amp; Frontend Dev</p>
            </div>
            <div class="md:border-r border-[#FDF8F3]/15 md:px-8">
              <p class="text-[#FDF8F3]/45 text-[0.6rem] uppercase tracking-[0.3em] mb-2">Ubicación</p>
              <p class="font-display font-semibold text-[#FDF8F3] text-sm">Lima, Perú</p>
            </div>
            <div class="md:pl-8">
              <p class="text-[#FDF8F3]/45 text-[0.6rem] uppercase tracking-[0.3em] mb-2">Disponibilidad</p>
              <p class="font-display font-semibold text-[#FDF8F3] text-sm">Abierta a proyectos</p>
            </div>
          </div>
        </div><!-- /BOTTOM -->

      </div><!-- /max-w container -->
    </section><!-- /about-hero -->

    <!-- ── BIO — Mi historia ──────────────────────────────────── -->
    <section class="px-6 md:px-12 lg:px-24 py-24 border-t border-[var(--color-border)]">
      <div class="max-w-[1600px] mx-auto">

        <!-- Título grande scroll-paint (full-width, encima de la grilla) -->
        <div class="mb-16 overflow-hidden">
          <p class="reveal text-[var(--color-text-muted)] text-xs uppercase tracking-[0.3em] mb-6 flex items-center gap-3" data-delay="0">
            <span class="w-6 h-[1px] bg-[var(--color-primary)]"></span>
            Mi historia
          </p>
          <h2 id="bio-paint-title"
              class="font-display font-semibold leading-[1.05] tracking-tight"
              style="font-size: clamp(3rem, 6vw, 6rem);">
            <span class="paint-word">Del</span>
            <span class="paint-word"> diseño</span>
            <span class="paint-word"> al</span>
            <span class="paint-word"> código</span><span class="paint-word">,</span><br/>
            <span class="paint-word">de</span>
            <span class="paint-word"> la</span>
            <span class="paint-word"> investigación</span>
            <span class="paint-word"> al</span>
            <span class="paint-word"> impacto</span><span class="paint-word">.</span>
          </h2>
        </div>

        <!-- Grid: textos + cita -->
        <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-24">

          <!-- col vacía izquierda para alinear con el grid anterior -->
          <div class="hidden lg:block lg:col-span-4"></div>

          <!-- Textos -->
          <div class="lg:col-span-8 space-y-8">
          <p class="reveal text-base md:text-lg leading-relaxed text-[var(--color-text-muted)]" data-delay="0.2">
            Estudié ingeniería de software y empecé mi camino desde lo técnico. Con el tiempo, el UX/UI apareció y me cambió la forma de ver los productos: entendí que no basta con que algo funcione, también tiene que ser claro, útil y fácil de usar.
          </p>
          <p class="reveal text-base md:text-lg leading-relaxed text-[var(--color-text-muted)]" data-delay="0.3">
            Hoy me estoy especializando en UX, con foco en investigación: me gusta observar, entender necesidades y convertir esos hallazgos en flujos e interfaces que resuelven problemas reales. Mi perfil técnico me permite trabajar muy de cerca con desarrollo, anticipar limitaciones y llevar el diseño a implementación cuando el proyecto lo requiere.
          </p>
          <!-- Cita integrada al final del bio -->
          <blockquote class="reveal border-l-2 border-[var(--color-primary)] pl-6 mt-2" data-delay="0.4">
            <p class="font-serif italic text-[clamp(1.05rem,1.8vw,1.35rem)] leading-[1.45] text-[var(--color-text)]">
              "El buen diseño es invisible: cuando algo funciona de verdad,
              nadie lo nota — <span class="text-[var(--color-primary)]">simplemente fluye.</span>"
            </p>
          </blockquote>
        </div>

      </div>
    </section>

    <!-- Skills Section -->
    <section>
      <!-- Header: fondo cherry -->
      <div class="px-6 md:px-12 lg:px-24 pt-20 pb-16 bg-[var(--color-primary)]" data-dark-header>
        <div class="max-w-[1600px] mx-auto grid grid-cols-1 lg:grid-cols-12 gap-8 items-end">
          <div class="lg:col-span-7">
            <p class="reveal text-[var(--color-bg)]/50 text-xs uppercase tracking-[0.4em] mb-5 flex items-center gap-3" data-delay="0">
              <span class="block w-8 h-[1px] bg-[var(--color-bg)]/30"></span>
              Habilidades
            </p>
            <h2 class="reveal font-display text-4xl md:text-5xl lg:text-6xl font-semibold leading-[1.1] text-[var(--color-bg)]" data-delay="0.1">
              Lo que hago
            </h2>
          </div>
          <div class="lg:col-span-5">
            <p class="reveal text-[var(--color-bg)]/60 text-base leading-relaxed" data-delay="0.2">
              Un conjunto de disciplinas que combino para crear productos digitales completos — desde la investigación hasta el código.
            </p>
          </div>
        </div>
      </div>

      <!-- Cards: fondo crema -->
      <div class="px-6 md:px-12 lg:px-24 py-16 ">
        <div class="max-w-[1600px] mx-auto">
          <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 divide-y lg:divide-y-0 divide-x-0 lg:divide-x divide-[var(--color-border)]">
            {skills.map((category, index) => (
              <div class="reveal group p-8 lg:p-10 flex flex-col" data-delay={0.1 + index * 0.1}>
                <div class="mb-8">
                  <span class="block text-[var(--color-text-muted)]/40 group-hover:text-[var(--color-primary)] text-xs font-mono tracking-widest transition-colors duration-300">
                    {String(index + 1).padStart(2, '0')}
                  </span>
                  <h3 class="font-display text-2xl font-semibold mt-1 text-[var(--color-text)] group-hover:text-[var(--color-primary)] transition-colors duration-300">
                    {category.name}
                  </h3>
                  <!-- Línea expand bajo el título -->
                  <span class="block mt-2 h-[1.5px] w-0 group-hover:w-full bg-[var(--color-primary)] transition-[width] duration-500 ease-[cubic-bezier(0.16,1,0.3,1)]"></span>
                </div>
                <ul class="space-y-2.5">
                  {category.items.map(item => (
                    <li class="text-[var(--color-text-muted)] text-sm flex items-start gap-3 leading-snug">
                      <span class="mt-[6px] w-1 h-1 rounded-full bg-[var(--color-primary)]/30 group-hover:bg-[var(--color-primary)]/70 shrink-0 transition-colors duration-300"></span>
                      {item}
                    </li>
                  ))}
                </ul>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>

    <!-- Experience Section -->
    <section class="exp-section border-t border-[var(--color-border)]">
      <div class="exp-scene">

        <!-- Palabra de fondo -->
        <div class="exp-bg-word" aria-hidden="true">EXPERIENCIA</div>

        <!-- Label arriba -->
        <div class="exp-header px-6 md:px-12 lg:px-24">
          <p class="exp-header-label">
            <span class="exp-header-line"></span>
            Trayectoria
          </p>
        </div>

        <!-- Stack de cards -->
        <div class="exp-stack px-6 md:px-12 lg:px-24">
          {experience.map((exp, index) => (
            <div class="exp-card waiting" data-card={index}>
              <div class="exp-card-inner">

                <!-- Cabecera: número + período -->
                <div class="exp-card-head">
                  <span class="exp-card-num">0{index + 1}</span>
                  <div class="exp-card-meta">
                    <span class="exp-card-period">{exp.period}</span>
                    <span class="exp-card-type">{exp.type}</span>
                  </div>
                </div>

                <!-- Divider -->
                <div class="exp-card-divider"></div>

                <!-- Rol + empresa -->
                <div class="exp-card-title-block">
                  <h3 class="exp-card-role">{exp.role}</h3>
                  <p class="exp-card-company">{exp.company}</p>
                </div>

                <!-- Descripción -->
                <p class="exp-card-desc">{exp.description}</p>

                <!-- Tags -->
                <div class="exp-card-tags">
                  {exp.skills.map(skill => (
                    <span class="exp-card-tag">{skill}</span>
                  ))}
                </div>

              </div>
            </div>
          ))}
        </div>

      </div>
    </section>

    <!-- Process Section -->
    <section class="px-6 md:px-12 lg:px-24 py-24 bg-[var(--color-bg)]">
      <div class="max-w-[1600px] mx-auto">
        <div class="mb-16">
          <p class="reveal text-[var(--color-primary)] text-xs uppercase tracking-[0.3em] mb-4 flex items-center gap-3" data-delay="0">
            <span class="w-8 h-[1px] bg-[var(--color-primary)]"></span>
            Mi proceso
          </p>
          <h2 class="reveal font-display text-3xl md:text-4xl lg:text-5xl font-semibold text-[var(--color-primary)]" data-delay="0.1">
            Cómo trabajo
          </h2>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-0 border-t border-[var(--color-primary)]/10">
          {[
            { num: '01', title: 'Descubrir', desc: 'Entender el problema, los usuarios y el contexto del negocio' },
            { num: '02', title: 'Definir', desc: 'Estructurar la información y definir los flujos de usuario' },
            { num: '03', title: 'Diseñar', desc: 'Crear interfaces visuales atractivas y funcionales' },
            { num: '04', title: 'Desarrollar', desc: 'Implementar el diseño en código limpio y performante' },
          ].map((step, index) => (
            <div class="reveal border-b md:border-b-0 md:border-r border-[var(--color-primary)]/10 last:border-0 px-0 py-10 md:px-8 lg:px-10" data-delay={0.1 + index * 0.1}>
              <p class="font-display text-5xl lg:text-6xl font-bold text-[var(--color-primary)]/15 mb-6 leading-none">{step.num}</p>
              <h3 class="font-display text-xl font-semibold text-[var(--color-primary)] mb-3">{step.title}</h3>
              <p class="text-[var(--color-primary)]/60 text-sm leading-relaxed">{step.desc}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

  </main>

  <Footer />
</Layout>

<style>
  /* ═══════════════════════════════════════
     ABOUT HERO — entrada al cargar (no scroll)
  ═══════════════════════════════════════ */
  @keyframes about-hero-in {
    from { opacity: 0; transform: translateY(20px); }
    to   { opacity: 1; transform: translateY(0);    }
  }

  .about-hero-item {
    opacity: 0;
    animation: about-hero-in 0.75s cubic-bezier(0.16, 1, 0.3, 1) forwards;
  }

  /* ═══════════════════════════════════════
     BIO — scroll-paint title
  ═══════════════════════════════════════ */
  #bio-paint-title .paint-word {
    display: inline-block;
    color: var(--color-text-muted);
    opacity: 0.22;
  }

  /* ═══════════════════════════════════════
     EXPERIENCE — scroll-stack section
  ═══════════════════════════════════════ */

  /* 300vh: 3 segmentos, uno por card */
  .exp-section {
    height: 300vh;
  }

  /* Escena — fondo rojo, viewport completo (GSAP ScrollTrigger la pinea) */
  .exp-scene {
    position: relative;
    height: 100vh;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    background: var(--color-primary);
  }

  /* ── Palabra de fondo ── */
  .exp-bg-word {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-display);
    font-size: clamp(5rem, 20vw, 18rem);
    font-weight: 800;
    letter-spacing: -0.04em;
    line-height: 1;
    color: #fff;
    opacity: 0.08;
    pointer-events: none;
    user-select: none;
    white-space: nowrap;
  }

  /* ── Label "Trayectoria" ── */
  .exp-header {
    position: relative;
    z-index: 2;
    padding-top: 2.5rem;
    padding-bottom: 0;
    flex-shrink: 0;
  }

  .exp-header-label {
    display: flex;
    align-items: center;
    gap: 0.625rem;
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.3em;
    color: rgba(255,255,255,0.5);
    margin: 0;
  }

  .exp-header-line {
    display: block;
    width: 2rem;
    height: 1px;
    background: rgba(255,255,255,0.35);
    flex-shrink: 0;
  }

  /* ── Stack de cards ── */
  .exp-stack {
    position: relative;
    z-index: 2;
    flex: 1;
    display: flex;
    align-items: center;
    perspective: 1400px;
  }

  /* ── Cada card ── */
  .exp-card {
    position: absolute;
    left: 0;
    right: 0;
    max-width: 820px;
    width: 100%;
    margin: 0 auto;
    padding-left: inherit;
    padding-right: inherit;
    transition:
      transform 0.8s cubic-bezier(0.16, 1, 0.3, 1),
      opacity   0.65s cubic-bezier(0.16, 1, 0.3, 1),
      filter    0.65s cubic-bezier(0.16, 1, 0.3, 1);
    will-change: transform, opacity, filter;
    transform-origin: center center;
  }

  /* Esperando abajo — viene desde la base, comprimida + perspectiva */
  .exp-card.waiting {
    transform: translateY(115%) scaleY(0.55) rotateX(22deg);
    opacity: 0;
    pointer-events: none;
    filter: blur(6px);
  }

  /* Activa — plana, centrada, nítida */
  .exp-card.active {
    transform: translateY(0) scaleY(1) rotateX(0deg);
    opacity: 1;
    pointer-events: auto;
    filter: blur(0px);
  }

  /* Sale por arriba — simétrico a la entrada pero invertido */
  .exp-card.exiting {
    transform: translateY(-115%) scaleY(0.55) rotateX(-22deg);
    opacity: 0;
    pointer-events: none;
    filter: blur(6px);
  }

  /* ── Interior de la card ── */
  .exp-card-inner {
    position: relative;
    background: var(--color-bg);
    border-radius: 0.75rem;
    padding: 2.5rem;
    overflow: hidden;
    box-shadow:
      0 40px 80px rgba(0,0,0,0.3),
      0 10px 30px rgba(0,0,0,0.15);
  }

  /* ── Cabecera: número + meta ── */
  .exp-card-head {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    margin-bottom: 1.5rem;
  }

  .exp-card-num {
    font-family: var(--font-display);
    font-size: clamp(3.5rem, 7vw, 6rem);
    font-weight: 800;
    line-height: 1;
    letter-spacing: -0.05em;
    color: var(--color-primary);
    opacity: 0.12;
    pointer-events: none;
    user-select: none;
    line-height: 0.9;
  }

  .exp-card-meta {
    text-align: right;
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    padding-top: 0.25rem;
  }

  .exp-card-period {
    font-size: 0.7rem;
    font-family: var(--font-mono, monospace);
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--color-text-muted);
  }

  .exp-card-type {
    font-size: 0.65rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-text-muted);
    opacity: 0.6;
  }

  /* ── Divisor ── */
  .exp-card-divider {
    height: 1px;
    background: var(--color-border);
    margin-bottom: 1.5rem;
  }

  /* ── Título y empresa ── */
  .exp-card-title-block {
    margin-bottom: 1.25rem;
  }

  .exp-card-role {
    font-family: var(--font-display);
    font-size: clamp(1.5rem, 3vw, 2.25rem);
    font-weight: 600;
    color: var(--color-text);
    line-height: 1.15;
    margin: 0 0 0.4rem;
  }

  .exp-card-company {
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--color-primary);
    letter-spacing: 0.03em;
    margin: 0;
  }

  /* ── Descripción ── */
  .exp-card-desc {
    font-size: 0.9rem;
    line-height: 1.7;
    color: var(--color-text-muted);
    margin: 0 0 1.5rem;
  }

  /* ── Tags ── */
  .exp-card-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .exp-card-tag {
    font-size: 0.7rem;
    font-weight: 500;
    padding: 0.35rem 0.85rem;
    border-radius: 999px;
    background: color-mix(in srgb, var(--color-primary) 7%, transparent);
    color: var(--color-primary);
    border: 1px solid color-mix(in srgb, var(--color-primary) 18%, transparent);
    letter-spacing: 0.03em;
  }

  /* ── Mobile: stack vertical sin efecto ── */
  @media (max-width: 767px) {
    .exp-section { height: auto; }

    .exp-scene {
      position: relative;
      height: auto;
      overflow: visible;
      padding: 3rem 0;
      background: var(--color-primary);
    }

    .exp-bg-word { display: none; }

    .exp-header {
      padding-top: 0;
      padding-bottom: 1.5rem;
    }

    .exp-header-label {
      color: var(--color-secondary);
    }

    .exp-stack {
      position: relative;
      flex-direction: column;
      gap: 1.25rem;
      align-items: stretch;
      perspective: none;
      margin-top: 0;
    }

    /* Título de sección mobile */
    .exp-stack::before {
      content: 'Experiencia';
      display: block;
      font-family: var(--font-serif);
      font-size: 2rem;
      font-weight: 500;
      font-style: italic;
      color: #FDF8F3;
      margin-bottom: 1.5rem;
      text-align: center;
    }

    .exp-card {
      position: relative;
      transform: none !important;
      opacity: 1 !important;
      pointer-events: auto !important;
      filter: none !important;
      max-width: 100%;
    }

    .exp-card-inner {
      padding: 1.5rem;
      box-shadow: 0 8px 24px rgba(0,0,0,0.1);
      border-radius: 1rem;
    }

    .exp-card-num { font-size: 3rem; }
  }
</style>

<script>
  /* ─── Experience scroll-pinned cards ───────────────────── */
  (async function () {
    const section = document.querySelector<HTMLElement>('.exp-section');
    const scene   = document.querySelector<HTMLElement>('.exp-scene');
    const cards   = document.querySelectorAll<HTMLElement>('.exp-card');
    const total   = cards.length; // 3

    if (!section || !scene || total === 0) return;

    const mq = window.matchMedia('(max-width: 767px)');
    if (mq.matches) return;

    const { gsap } = await import('gsap');
    const { ScrollTrigger } = await import('gsap/ScrollTrigger');
    gsap.registerPlugin(ScrollTrigger);

    // Estados posibles para cada card dado el índice activo:
    // -1 = exiting (ya fue mostrada y salió por arriba)
    //  0 = active  (visible ahora)
    // +1 = waiting (aún no aparece)
    function setCards(activeIdx: number) {
      cards.forEach((card, i) => {
        card.classList.remove('active', 'waiting', 'exiting');
        if (i < activeIdx)        card.classList.add('exiting');
        else if (i === activeIdx) card.classList.add('active');
        else                      card.classList.add('waiting');
      });
    }

    // Estado inicial: todas en waiting
    cards.forEach(c => c.classList.add('waiting'));

    // ScrollTrigger pin — la escena se pega mientras scrolleas la sección
    ScrollTrigger.create({
      trigger: section,
      start: 'top top',
      end: 'bottom bottom',
      pin: scene,
      pinSpacing: false,
      onUpdate: (self) => {
        // 3 segmentos: [0-0.33] card0, [0.33-0.66] card1, [0.66-1] card2
        const slot    = self.progress * total; // 0 → 3
        const cardIdx = Math.min(total - 1, Math.floor(slot));
        setCards(cardIdx);
      },
    });
  })();

  /* ─── Bio scroll-paint ─────────────────────────────────── */
  (async function () {
    const title = document.querySelector<HTMLElement>('#bio-paint-title');
    if (!title) return;

    const { gsap } = await import('gsap');
    const { ScrollTrigger } = await import('gsap/ScrollTrigger');
    gsap.registerPlugin(ScrollTrigger);

    const words = title.querySelectorAll<HTMLElement>('.paint-word');

    gsap.to(words, {
      opacity: 1,
      color: 'var(--color-text)',
      stagger: 0.06,
      ease: 'none',
      scrollTrigger: {
        trigger: title,
        start: 'top 80%',
        end: 'bottom 30%',
        scrub: 0.6,
      },
    });
  })();
</script>
