---
interface Props {
  class?: string;
}

const { class: className = '' } = Astro.props;
---

<header class={`fixed top-0 left-0 right-0 z-50 ${className}`} id="main-header">
  <nav class="header-nav flex items-center justify-between px-6 md:px-12 py-5 transition-all duration-500">
    <!-- Logo -->
    <a href="/" class="logo-link group relative flex items-center">
      <img 
        src="/logo.svg" 
        alt="Julisa Leon" 
        id="header-logo"
        class="h-8 md:h-10 w-auto transition-all duration-500 group-hover:scale-105"
      />
    </a>

    <!-- Navigation Links -->
    <div class="hidden md:flex items-center gap-10">
      <a href="/work" class="nav-link group relative text-sm uppercase tracking-widest transition-colors duration-300">
        <span class="relative z-10">Proyectos</span>
        <span class="nav-link-line absolute bottom-0 left-0 w-0 h-[1px] transition-all duration-500 ease-out group-hover:w-full"></span>
      </a>
      <a href="/about" class="nav-link group relative text-sm uppercase tracking-widest transition-colors duration-300">
        <span class="relative z-10">Sobre mí</span>
        <span class="nav-link-line absolute bottom-0 left-0 w-0 h-[1px] transition-all duration-500 ease-out group-hover:w-full"></span>
      </a>
      <a href="/contact" class="nav-cta group relative overflow-hidden px-6 py-2.5 text-sm uppercase tracking-widest rounded-full border transition-all duration-300">
        <span class="relative z-10">Contacto</span>
      </a>
    </div>

    <!-- Mobile Menu Button -->
    <button class="md:hidden" id="menu-toggle" aria-label="Toggle menu">
      <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 6h16M4 12h16M4 18h16" />
      </svg>
    </button>
  </nav>
</header>

<!-- Mobile Menu -->
<div class="fixed inset-0 bg-[var(--color-primary)] z-40 hidden" id="mobile-menu">
  <div class="absolute inset-0 overflow-hidden">
    <img src="/mariposa.png" alt="" class="absolute top-20 right-10 w-16 h-16 opacity-20 animate-float-slow" />
    <img src="/mariposa2.png" alt="" class="absolute bottom-32 left-10 w-12 h-12 opacity-15 animate-float-delayed" />
  </div>
  <div class="flex flex-col items-center justify-center h-full gap-8 relative z-10">
    <a href="/" class="mb-8">
      <img src="/logo.svg" alt="Julisa Leon" class="h-12 brightness-0 invert" />
    </a>
    <a href="/work" class="mobile-nav-link text-[#FDF8F3] text-4xl font-serif font-medium hover:opacity-80 transition-all duration-300 hover:translate-x-2">Proyectos</a>
    <a href="/about" class="mobile-nav-link text-[#FDF8F3] text-4xl font-serif font-medium hover:opacity-80 transition-all duration-300 hover:translate-x-2">Sobre mí</a>
    <a href="/contact" class="mobile-nav-link text-[#FDF8F3] text-4xl font-serif font-medium hover:opacity-80 transition-all duration-300 hover:translate-x-2">Contacto</a>
  </div>
  <button class="absolute top-6 right-6 text-[#FDF8F3] p-2 hover:rotate-90 transition-transform duration-300" id="menu-close" aria-label="Close menu">
    <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8" fill="none" viewBox="0 0 24 24" stroke="currentColor">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M6 18L18 6M6 6l12 12" />
    </svg>
  </button>
</div>

<style>
  @keyframes float-slow {
    0%, 100% { transform: translateY(0) rotate(0deg); }
    50% { transform: translateY(-20px) rotate(5deg); }
  }
  
  @keyframes float-delayed {
    0%, 100% { transform: translateY(0) rotate(0deg); }
    50% { transform: translateY(-15px) rotate(-5deg); }
  }
  
  .animate-float-slow  { animation: float-slow  6s ease-in-out infinite; }
  .animate-float-delayed { animation: float-delayed 8s ease-in-out infinite; animation-delay: 2s; }

  /* ─── Modo claro (default): fondo crema, letras cherry ──── */
  .header-nav {
    background: var(--color-bg);
    border-bottom: 1px solid var(--color-border);
  }

  .nav-link          { color: var(--color-text-muted); }
  .nav-link:hover    { color: var(--color-primary); }
  .nav-link-line     { background: var(--color-primary); }

  .nav-cta {
    color: var(--color-primary);
    border-color: var(--color-border);
  }
  .nav-cta:hover {
    border-color: var(--color-primary);
    background: var(--color-primary);
    color: #FDF8F3;
  }

  #menu-toggle { color: var(--color-text); }

  /* ─── Modo oscuro: fondo rojo, letras crema ─────────────── */
  #main-header.header--dark .header-nav {
    background: var(--color-primary-dark);
    border-bottom-color: transparent;
  }

  #main-header.header--dark .nav-link          { color: rgba(253,248,243,0.65); }
  #main-header.header--dark .nav-link:hover    { color: #FDF8F3; }
  #main-header.header--dark .nav-link-line     { background: rgba(253,248,243,0.5); }

  #main-header.header--dark .nav-cta {
    color: rgba(253,248,243,0.75);
    border-color: rgba(253,248,243,0.25);
    background: transparent;
  }
  #main-header.header--dark .nav-cta:hover {
    color: #FDF8F3;
    border-color: rgba(253,248,243,0.55);
    background: transparent;
  }

  #main-header.header--dark #menu-toggle { color: rgba(253,248,243,0.8); }

  /* ─── Scroll compacto ────────────────────────────────────── */
  header.scrolled .header-nav {
    padding-top: 0.75rem;
    padding-bottom: 0.75rem;
  }

  header.scrolled #header-logo { height: 1.75rem; }

  @media (min-width: 768px) {
    header.scrolled #header-logo { height: 2rem; }
  }
</style>

<script>
  const menuToggle  = document.getElementById('menu-toggle');
  const menuClose   = document.getElementById('menu-close');
  const mobileMenu  = document.getElementById('mobile-menu');
  const header      = document.getElementById('main-header');
  const logo        = document.getElementById('header-logo');

  /* ── Logo: invertir según tema ─────────────────────────────
     dark → brightness-0 invert (crema)
     light → normal (rojo)
  ────────────────────────────────────────────────────────── */
  function applyLogoTheme(dark: boolean) {
    if (!logo) return;
    if (dark) {
      logo.classList.add('brightness-0', 'invert', 'opacity-90');
      logo.classList.remove('opacity-100');
    } else {
      logo.classList.remove('brightness-0', 'invert', 'opacity-90');
      logo.classList.add('opacity-100');
    }
  }

  /* ── IntersectionObserver: observa secciones con fondo oscuro ─
     Cuando cualquier elemento [data-dark-header] intersecta
     con el top del viewport, el header cambia a modo oscuro.
  ────────────────────────────────────────────────────────── */
  const darkSections = document.querySelectorAll<HTMLElement>('[data-dark-header]');
  const activeDarkSections = new Set<Element>();

  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          activeDarkSections.add(entry.target);
        } else {
          activeDarkSections.delete(entry.target);
        }
      });
      const isDark = activeDarkSections.size > 0;
      header?.classList.toggle('header--dark', isDark);
      applyLogoTheme(isDark);
    },
    {
      // Franja de detección: solo la zona donde vive el header (~80px desde arriba)
      rootMargin: '0px 0px -85% 0px',
      threshold: 0,
    }
  );

  darkSections.forEach(el => observer.observe(el));

  // Estado inicial sincrónico (evita flash al cargar /about directamente)
  const initialDark = Array.from(darkSections).some(el => {
    const rect = el.getBoundingClientRect();
    return rect.top < window.innerHeight * 0.15 && rect.bottom > 0;
  });
  if (initialDark) {
    header?.classList.add('header--dark');
    applyLogoTheme(true);
  }

  /* ── Mobile menu ───────────────────────────────────────── */
  menuToggle?.addEventListener('click', () => {
    mobileMenu?.classList.remove('hidden');
    document.body.style.overflow = 'hidden';
  });

  menuClose?.addEventListener('click', () => {
    mobileMenu?.classList.add('hidden');
    document.body.style.overflow = '';
  });

  mobileMenu?.querySelectorAll('a').forEach(link => {
    link.addEventListener('click', () => {
      mobileMenu?.classList.add('hidden');
      document.body.style.overflow = '';
    });
  });

  /* ── Scroll compacto ───────────────────────────────────── */
  window.addEventListener('scroll', () => {
    if (window.scrollY > 50) {
      header?.classList.add('scrolled');
    } else {
      header?.classList.remove('scrolled');
    }
  });
</script>
