---
const stats = [
  {
    value: 4,
    suffix: '+',
    label: 'Años de\nexperiencia',
    accent: false,
  },
  {
    value: 10,
    suffix: '+',
    label: 'Proyectos\ncompletados',
    accent: true, // resaltado con color primario
  },
  {
    value: 100,
    suffix: '%',
    label: 'Clientes\nsatisfechos',
    accent: false,
  },
];
---

<section class="stats-section py-16 md:py-20 px-6 md:px-12 lg:px-24 border-t border-b border-[var(--color-border)]">
  <div class="max-w-[1600px] mx-auto">
    <div class="stats-grid">
      {stats.map((stat, i) => (
        <div class="stat-item reveal" data-delay={i * 0.15}>
          <!-- Numero animado -->
          <div class="stat-number">
            <span
              class:list={['counter', stat.accent && 'stat-accent']}
              data-target={stat.value}
            >0</span><span class:list={['stat-suffix', stat.accent && 'stat-accent']}>{stat.suffix}</span>
          </div>

          <!-- Etiqueta -->
          <p class="stat-label">
            {stat.label.split('\n').map((line, j) => (
              <span>
                {line}
                {j === 0 && <br />}
              </span>
            ))}
          </p>

          <!-- Separador vertical (excepto en el ultimo) -->
          {i < stats.length - 1 && (
            <div class="stat-divider" aria-hidden="true"></div>
          )}
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  /* ─── Grid de stats ─── */
  .stats-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 0;
    position: relative;
  }

  @media (max-width: 640px) {
    .stats-grid {
      grid-template-columns: 1fr;
      gap: 2.5rem;
    }
  }

  /* ─── Item individual ─── */
  .stat-item {
    position: relative;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    padding: 1.5rem 2rem;
    gap: 0.75rem;
  }

  /* ─── Numero grande ─── */
  .stat-number {
    display: flex;
    align-items: baseline;
    gap: 0.1em;
    line-height: 1;
  }

  .counter,
  .stat-suffix {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: clamp(3.5rem, 7vw, 6rem);
    color: var(--color-text);
    letter-spacing: -0.03em;
    line-height: 1;
  }

  /* Variante resaltada */
  .stat-accent {
    color: var(--color-primary);
  }

  /* ─── Etiqueta ─── */
  .stat-label {
    font-family: var(--font-body);
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--color-text-muted);
    line-height: 1.6;
  }

  /* ─── Separador vertical entre items ─── */
  .stat-divider {
    position: absolute;
    right: 0;
    top: 20%;
    height: 60%;
    width: 1px;
    background: var(--color-border);
  }

  /* Ocultar separadores en mobile */
  @media (max-width: 640px) {
    .stat-divider {
      display: none;
    }
  }
</style>
