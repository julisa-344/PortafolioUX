---
interface Skill {
  name: string;
  items: string[];
}

interface Props {
  skills: Skill[];
}

const { skills } = Astro.props;
---

<section class="py-24 md:py-32 px-6 md:px-12 lg:px-24 border-t border-[var(--color-border)]">
  <div class="max-w-[1600px] mx-auto">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 lg:gap-24">
      <!-- Left column: About text -->
      <div class="about-left">

        <p class="reveal text-[var(--color-text-muted)] text-sm uppercase tracking-[0.3em] mb-4" data-delay="0">
          Sobre mí
        </p>
        <h2 class="reveal font-display text-3xl md:text-4xl lg:text-5xl font-semibold mb-8" data-delay="0.1">
          UX Designer que programa
        </h2>
        <div class="space-y-6">
          <p class="reveal text-[var(--color-text-muted)] text-lg leading-relaxed" data-delay="0.2">
            Diseño experiencias digitales centradas en el usuario, desde la investigación 
            hasta la implementación en código. Mi enfoque combina metodologías UX rigurosas 
            con habilidades técnicas que me permiten llevar los diseños a producción.
          </p>
          <p class="reveal text-[var(--color-text-muted)] text-lg leading-relaxed" data-delay="0.3">
            Trabajo directamente con clientes, liderando reuniones, definiendo objetivos, 
            resolviendo flujos y presentando soluciones de diseño justificadas con data.
          </p>
        </div>
        
        <a 
          href="/about" 
          class="reveal group inline-flex items-center gap-3 mt-8 text-[var(--color-primary)] hover:text-[var(--color-text-muted)] transition-colors"
          data-delay="0.4"
        >
          <span class="line-reveal">Conocer más</span>
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 transition-transform group-hover:translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
          </svg>
        </a>
      </div>

      <!-- Right column: Skills -->
      <div class="space-y-12">
        {skills.map((skill, skillIndex) => (
          <div class="reveal" data-delay={0.2 + skillIndex * 0.1}>
            <h3 class="text-sm uppercase tracking-[0.2em] text-[var(--color-text-muted)] mb-4">
              {skill.name}
            </h3>
            <div class="flex flex-wrap gap-2">
              {skill.items.map(item => (
                <span class="tag">{item}</span>
              ))}
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>

<style>
  /* ─── Columna izquierda: contexto de posicionamiento ─── */
  .about-left {
    position: relative;
    overflow: hidden; /* recorta los numeros que se salen */
  }

  /* ─── Numeros decorativos ─── */
  .deco-number {
    position: absolute;
    font-family: var(--font-display);
    font-weight: 800;
    line-height: 1;
    color: var(--color-primary);
    opacity: 0.04;
    pointer-events: none;
    user-select: none;
    letter-spacing: -0.05em;
    z-index: 0;
  }

  /* "4+" — esquina superior derecha */
  .deco-number-1 {
    font-size: clamp(8rem, 18vw, 16rem);
    top: -1.5rem;
    right: -1rem;
  }

  /* "10+" — esquina inferior izquierda */
  .deco-number-2 {
    font-size: clamp(6rem, 14vw, 12rem);
    bottom: 3rem;
    left: -0.5rem;
  }

  /* Los elementos de texto deben quedar encima */
  .about-left > *:not(.deco-number) {
    position: relative;
    z-index: 1;
  }
</style>
