---
interface Props {
  src: string;
  alt: string;
  scrollable?: boolean;
}

const { src, alt, scrollable = true } = Astro.props;
---

<div class="phone-mockup">
  <div class:list={["phone-screen", { scrollable }]}>
    <img 
      src={src} 
      alt={alt} 
      loading="lazy"
      decoding="async"
    />
  </div>
</div>

<style>
  .phone-mockup {
    position: relative;
    background-color: var(--color-text, #1a1a1a);
    border-radius: 40px;
    padding: 8px;
    aspect-ratio: 9 / 19.5;
    max-height: 600px;
    width: auto;
    box-shadow: 
      inset 0 0 0 2px rgba(255, 255, 255, 0.1);
  }

  .phone-screen {
    width: 100%;
    height: 100%;
    border-radius: 35px;
    overflow: hidden;
    background-color: #000;
  }

  .phone-screen.scrollable {
    overflow-y: auto;
  }

  .phone-screen:not(.scrollable) img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .phone-screen.scrollable img {
    width: 100%;
    height: auto;
    display: block;
  }

  /* Scrollbar styling */
  .phone-screen.scrollable::-webkit-scrollbar {
    width: 4px;
  }

  .phone-screen.scrollable::-webkit-scrollbar-track {
    background: transparent;
  }

  .phone-screen.scrollable::-webkit-scrollbar-thumb {
    background-color: var(--color-primary, #6366f1);
    border-radius: 4px;
  }

  /* Firefox scrollbar */
  .phone-screen.scrollable {
    scrollbar-width: thin;
    scrollbar-color: var(--color-primary, #6366f1) transparent;
  }
</style>
