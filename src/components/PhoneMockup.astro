---
interface Props {
  src: string;
  alt: string;
  scrollable?: boolean;
}

const { src, alt, scrollable = true } = Astro.props;
---

<div class="phone-mockup">
  <div class:list={["phone-screen", { scrollable }]}>
    <img 
      src={src} 
      alt={alt} 
      loading="lazy"
      decoding="async"
    />
  </div>
</div>

<style>
  .phone-mockup {
    position: relative;
    /* Marco exterior cream para contrastar con fondo cherry */
    background-color: #FDF8F3;
    border-radius: 44px;
    padding: 3px;
    aspect-ratio: 9 / 19.5;
    max-height: 600px;
    width: auto;
    box-shadow:
      /* Sombra difusa más suave */
      0 20px 40px rgba(0, 0, 0, 0.15),
      /* Borde interior sutil */
      inset 0 0 0 1px rgba(255, 255, 255, 0.2);
  }

  @media (max-width: 479px) {
    .phone-mockup {
      max-height: 380px;
    }
  }

  @media (max-width: 767px) {
    .phone-mockup {
      box-shadow:
        0 12px 24px rgba(0, 0, 0, 0.12),
        inset 0 0 0 1px rgba(255, 255, 255, 0.15);
    }
  }

  /* Capa intermedia entre el borde cherry y la pantalla */
  .phone-mockup::before {
    content: '';
    position: absolute;
    inset: 3px;
    border-radius: 42px;
    background: #111;
    z-index: 0;
  }

  .phone-screen {
    position: relative;
    z-index: 1;
    width: 100%;
    height: 100%;
    border-radius: 40px;
    overflow: hidden;
    background-color: #000;
  }

  .phone-screen.scrollable {
    overflow-y: auto;
  }

  .phone-screen:not(.scrollable) img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .phone-screen.scrollable img {
    width: 100%;
    height: auto;
    display: block;
  }

  /* Scrollbar styling */
  .phone-screen.scrollable::-webkit-scrollbar {
    width: 3px;
  }

  .phone-screen.scrollable::-webkit-scrollbar-track {
    background: transparent;
  }

  .phone-screen.scrollable::-webkit-scrollbar-thumb {
    background-color: var(--color-primary);
    border-radius: 4px;
  }

  .phone-screen.scrollable {
    scrollbar-width: thin;
    scrollbar-color: var(--color-primary) transparent;
  }
</style>
