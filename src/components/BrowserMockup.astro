---
interface Props {
  src: string;
  alt: string;
  height?: string;
  label?: string;
  url?: string;
}

const { src, alt, height = "auto", label, url = "example.com" } = Astro.props;
const useFixedHeight = height !== "auto";
---

<div class="browser-mockup">
  <!-- Browser Chrome -->
  <div class="browser-chrome">
    <!-- Control Dots -->
    <div class="browser-dots">
      <span class="dot dot-red"></span>
      <span class="dot dot-yellow"></span>
      <span class="dot dot-green"></span>
    </div>
    
    <!-- Address Bar -->
    <div class="browser-address-bar">
      <svg class="lock-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor">
        <path d="M12 1L3 5v6c0 5.55 3.84 10.74 9 12 5.16-1.26 9-6.45 9-12V5l-9-4zm0 10.99h7c-.53 4.12-3.28 7.79-7 8.94V12H5V6.3l7-3.11v8.8z"/>
      </svg>
      <span class="url">{url}</span>
    </div>
  </div>

  <!-- Content Area -->
  <div 
    class={`browser-content ${useFixedHeight ? 'with-scroll' : 'auto-height'}`}
    style={useFixedHeight ? `height: ${height}` : ''}
    data-lenis-prevent={useFixedHeight ? true : undefined}
  >
    <img src={src} alt={alt} class="browser-screenshot" loading="lazy" />
  </div>
  
  <!-- Label Badge -->
  {label && (
    <div class="browser-label">
      <span>{label}</span>
    </div>
  )}
</div>

<style>
  .browser-mockup {
    border-radius: 12px;
    overflow: hidden;
    background: var(--color-bg);
    box-shadow: 
      0 4px 6px -1px rgba(103, 6, 38, 0.08),
      0 2px 4px -1px rgba(103, 6, 38, 0.04),
      0 10px 30px -10px rgba(103, 6, 38, 0.12);
    transition: box-shadow 0.4s var(--ease-out-expo), transform 0.4s var(--ease-out-expo);
    position: relative;
  }

  .browser-mockup:hover {
    transform: translateY(-4px);
    box-shadow: 
      0 10px 15px -3px rgba(103, 6, 38, 0.12),
      0 4px 6px -2px rgba(103, 6, 38, 0.06),
      0 25px 50px -15px rgba(103, 6, 38, 0.2);
  }

  /* Browser Chrome */
  .browser-chrome {
    background: linear-gradient(180deg, var(--color-bg-secondary) 0%, var(--color-bg-tertiary) 100%);
    padding: 12px 16px;
    border-bottom: 1px solid var(--color-border);
    display: flex;
    align-items: center;
    gap: 12px;
  }

  /* Control Dots */
  .browser-dots {
    display: flex;
    gap: 8px;
    align-items: center;
    flex-shrink: 0;
  }

  .dot {
    width: 12px;
    height: 12px;
    border-radius: 50%;
    opacity: 0.7;
    transition: opacity 0.3s ease;
  }

  .browser-mockup:hover .dot {
    opacity: 1;
  }

  .dot-red { background: #ff5f56; }
  .dot-yellow { background: #ffbd2e; }
  .dot-green { background: #27c93f; }

  /* Address Bar */
  .browser-address-bar {
    flex: 1;
    display: flex;
    align-items: center;
    gap: 8px;
    background: rgba(255, 255, 255, 0.6);
    padding: 6px 12px;
    border-radius: 6px;
    border: 1px solid var(--color-border);
    min-width: 0;
  }

  .lock-icon {
    width: 14px;
    height: 14px;
    color: var(--color-text-muted);
    flex-shrink: 0;
  }

  .url {
    font-size: 13px;
    color: var(--color-text-muted);
    font-weight: 500;
    letter-spacing: 0.01em;
    user-select: none;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  /* Label Badge */
  .browser-label {
    position: absolute;
    bottom: 12px;
    left: 12px;
    background: var(--color-primary);
    color: var(--color-bg);
    padding: 6px 14px;
    border-radius: 20px;
    font-size: 11px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    opacity: 0;
    transform: translateY(8px);
    transition: all 0.3s var(--ease-out-expo);
  }

  .browser-mockup:hover .browser-label {
    opacity: 1;
    transform: translateY(0);
  }

  /* Content Area - Auto Height */
  .browser-content.auto-height {
    background: #fff;
    position: relative;
  }

  /* Content Area - Fixed Height with Scroll */
  .browser-content.with-scroll {
    overflow-y: auto;
    overflow-x: hidden;
    background: #fff;
    position: relative;
    scroll-behavior: smooth;
  }

  /* Custom Scrollbar */
  .browser-content.with-scroll::-webkit-scrollbar {
    width: 8px;
  }

  .browser-content.with-scroll::-webkit-scrollbar-track {
    background: var(--color-bg-secondary);
  }

  .browser-content.with-scroll::-webkit-scrollbar-thumb {
    background: var(--color-primary);
    border-radius: 4px;
    border: 2px solid var(--color-bg-secondary);
  }

  .browser-content.with-scroll::-webkit-scrollbar-thumb:hover {
    background: var(--color-primary-dark);
  }

  .browser-content.with-scroll {
    scrollbar-width: thin;
    scrollbar-color: var(--color-primary) var(--color-bg-secondary);
  }

  /* Screenshot Image */
  .browser-screenshot {
    width: 100%;
    height: auto;
    display: block;
  }

  /* Responsive adjustments */
  @media (max-width: 768px) {
    .browser-chrome {
      padding: 10px 12px;
    }

    .browser-address-bar {
      padding: 4px 8px;
    }

    .url {
      font-size: 11px;
    }

    .dot {
      width: 10px;
      height: 10px;
    }
    
    .browser-label {
      display: none;
    }
  }
</style>
