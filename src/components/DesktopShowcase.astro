---
import BrowserMockup from './BrowserMockup.astro';

interface Page {
  src: string;
  alt: string;
  label: string;
  url?: string;
}

interface Section {
  title: string;
  pages: Page[];
  columns?: 2 | 3 | 4;
}

interface Props {
  title?: string;
  subtitle?: string;
  sections: Section[];
}

const { 
  title = "Pantallas Desktop", 
  subtitle = "Diseño UI",
  sections 
} = Astro.props;

// Helper function to determine grid columns class
const getGridClass = (columns: number = 2, pageCount: number) => {
  const cols = columns || Math.min(pageCount, 2);
  switch(cols) {
    case 2: return 'grid-cols-1 lg:grid-cols-2';
    case 3: return 'grid-cols-1 md:grid-cols-2 lg:grid-cols-3';
    case 4: return 'grid-cols-1 md:grid-cols-2 xl:grid-cols-4';
    default: return 'grid-cols-1 lg:grid-cols-2';
  }
};
---

<section class="py-24 border-t border-[var(--color-border)] overflow-hidden">
  <div class="max-w-[1800px] mx-auto px-6 md:px-12 lg:px-16">
    <!-- Section Header -->
    <div class="text-center mb-16">
      <p class="reveal text-[var(--color-text-muted)] text-sm uppercase tracking-[0.3em] mb-4" data-delay="0">
        {subtitle}
      </p>
      <h2 class="reveal font-serif text-4xl md:text-5xl lg:text-6xl font-medium" data-delay="0.1">
        {title}
      </h2>
    </div>

    <!-- Dynamic Sections -->
    <div class="space-y-24">
      {sections.map((section, sectionIndex) => (
        <div>
          <h3 class="reveal font-serif text-2xl md:text-3xl font-medium mb-10 text-[var(--color-text)]" data-delay="0">
            {section.title}
          </h3>
          <div class={`grid ${getGridClass(section.columns, section.pages.length)} gap-8`}>
            {section.pages.map((page, index) => (
              <div class="reveal" data-delay={0.1 + index * 0.05}>
                <BrowserMockup 
                  src={page.src} 
                  alt={page.alt} 
                  label={page.label} 
                  url={page.url} 
                  height="500px"
                />
              </div>
            ))}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
