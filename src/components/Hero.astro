---
import FloatingElements from './FloatingElements.astro';

interface Props {
  title: string;
  subtitle: string;
  scrollText?: string;
}

const { title, subtitle, scrollText = "Scroll para explorar" } = Astro.props;

// Split title into words for animation, mark words for italic styling
const words = title.split(' ');
const italicWords = ['experiencias', 'conectan', 'realidad']; // Words to style in italic serif
---

<section class="relative min-h-screen flex flex-col justify-center px-6 md:px-12 lg:px-24 pt-32 md:pt-36 overflow-hidden">
  <!-- Floating Elements -->
  <FloatingElements variant="hero" intensity="medium" />
  
  <!-- Background gradient -->
  <div class="absolute inset-0 bg-gradient-to-b from-transparent via-transparent to-[var(--color-bg)] pointer-events-none"></div>
  
  <!-- Decorative circles -->
  <div class="absolute top-1/3 right-10 w-[500px] h-[500px] rounded-full border border-[var(--color-primary)]/5 pointer-events-none"></div>
  <div class="absolute top-1/3 right-10 w-[400px] h-[400px] rounded-full border border-[var(--color-primary)]/5 pointer-events-none"></div>
  
  <!-- Content -->
  <div class="relative z-10 max-w-[1600px] mx-auto w-full">
    <!-- Subtitle with decorative lines -->
    <p class="reveal text-[var(--color-text-muted)] text-sm md:text-base uppercase tracking-[0.3em] mb-8 flex items-center gap-3" data-delay="0.2">
      <span class="w-8 h-[1px] bg-[var(--color-primary)]"></span>
      <span>{subtitle}</span>
      <span class="w-12 h-[1px] bg-[var(--color-border)]"></span>
    </p>
    
    <!-- Main Title with mixed typography -->
    <h1 class="font-display font-semibold text-4xl sm:text-5xl md:text-6xl lg:text-7xl xl:text-8xl leading-[1.1] tracking-tight mb-10">
      {words.map((word, index) => {
        const isItalic = italicWords.some(iw => word.toLowerCase().includes(iw.toLowerCase()));
        return (
          <span 
            class={`reveal inline-block mr-[0.3em] ${isItalic ? 'font-serif italic text-[var(--color-primary)]' : ''}`} 
            data-delay={0.3 + index * 0.08}
          >
            {word}
          </span>
        );
      })}
    </h1>

    <!-- Description -->
    <div class="reveal max-w-2xl" data-delay="0.7">
      <p class="text-[var(--color-text-muted)] text-lg md:text-xl leading-relaxed">
        <slot />
      </p>
    </div>

    <!-- CTA Buttons -->
    <div class="reveal flex flex-wrap gap-4 mt-12" data-delay="0.9">
      <a href="/work" class="group magnetic relative inline-flex items-center gap-3 px-8 py-4 bg-[var(--color-primary)] text-[#FDF8F3] font-medium rounded-full overflow-hidden transition-all duration-300 hover:shadow-xl hover:shadow-[var(--color-primary)]/25">
        <span class="relative z-10">Ver proyectos</span>
        <svg xmlns="http://www.w3.org/2000/svg" class="relative z-10 h-4 w-4 transition-transform duration-300 group-hover:translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
        </svg>
        <!-- Hover background -->
        <div class="absolute inset-0 bg-[var(--color-primary-dark)] transform translate-y-full transition-transform duration-300 group-hover:translate-y-0"></div>
      </a>
      <a href="/about" class="group magnetic inline-flex items-center gap-3 px-8 py-4 border-2 border-[var(--color-border)] text-[var(--color-text)] font-medium rounded-full hover:border-[var(--color-primary)] hover:text-[var(--color-primary)] transition-all duration-300">
        <span>Sobre mí</span>
        <span class="w-2 h-2 rounded-full bg-current opacity-0 group-hover:opacity-100 transition-opacity duration-300 pulse-glow"></span>
      </a>
    </div>
  </div>

  <!-- Scroll indicator (right side for balance) -->
  <div class="absolute bottom-12 right-6 md:right-12 lg:right-24 reveal" data-delay="1.2">
    <div class="flex items-center gap-4">
      <span class="text-xs uppercase tracking-widest text-[var(--color-text-muted)] writing-vertical">
        {scrollText}
      </span>
      <div class="w-[1px] h-16 bg-[var(--color-border)] relative overflow-hidden">
        <div class="absolute top-0 left-0 w-full h-full bg-[var(--color-primary)] animate-scroll-line"></div>
      </div>
    </div>
  </div>
</section>

<style>
  .writing-vertical {
    writing-mode: vertical-rl;
    text-orientation: mixed;
  }
</style>
