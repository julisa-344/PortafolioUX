---
import FloatingElements from './FloatingElements.astro';

interface Props {
  title: string;
  subtitle: string;
  scrollText?: string;
}

const { title, subtitle, scrollText = "Scroll para explorar" } = Astro.props;

// El título se parte en dos líneas: primera mitad y segunda mitad
// Se pasa como "Línea 1 / Línea 2" usando el separador "/"
const titleParts = title.includes('/') ? title.split('/') : [title];

// Palabras que van en serif italic cherry
const italicWords = ['diseño', 'código', 'digital', 'investigación', 'producción'];
---

<section class="hero-section" data-hero="home">

  <!-- ─── MARIPOSA — elemento derecho ───────────────────────── -->
  <div class="hero-butterfly-zone" id="hero-butterfly-zone">
    <img
      src="/mariposa.png"
      alt=""
      class="hero-butterfly-main"
      loading="eager"
    />
  </div>

  <!-- ─── Contenido ─────────────────────────────────────────── -->
  <div class="hero-inner">

    <!-- Rol / label -->
    <p class="hero-label" id="hero-label">
      <span class="hero-label-line"></span>
      {subtitle}
    </p>

    <!-- Título grande -->
    <h1 class="hero-heading" id="hero-heading" aria-label={titleParts.join(' ')}>
      {titleParts.map((line) => (
        <span class="hero-heading-line">
          {line.trim().split(' ').map((word) => {
            const clean = word.toLowerCase().replace(/[.,;:!?]/g, '');
            const isAccent = italicWords.some(iw => clean.includes(iw));
            return (
              <span class="hero-word-wrap">
                <span class={`hero-word${isAccent ? ' hero-word--accent font-serif italic' : ''}`}>
                  {word}
                </span>
              </span>
            );
          })}
        </span>
      ))}
    </h1>

    <!-- Descripción — justo debajo del título -->
    <div class="hero-bottom-left" id="hero-bottom-left">
      <p class="hero-desc">
        <slot />
      </p>
      <div class="hero-ctas">
        <a
          href="/work"
          class="group magnetic hero-btn-primary relative inline-flex items-center gap-2 overflow-hidden"
        >
          <span class="relative z-10">Ver proyectos</span>
          <svg xmlns="http://www.w3.org/2000/svg" class="relative z-10 h-3.5 w-3.5 transition-transform duration-300 group-hover:translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
          </svg>
          <div class="absolute inset-0 bg-[var(--color-primary-dark)] transform translate-y-full transition-transform duration-300 group-hover:translate-y-0"></div>
        </a>
        <a href="/about" class="group magnetic hero-btn-ghost inline-flex items-center gap-2">
          Sobre mí
          <span class="w-1 h-1 rounded-full bg-current opacity-0 group-hover:opacity-100 transition-opacity duration-300"></span>
        </a>
      </div>
    </div>

  </div><!-- /hero-inner -->

  <!-- ─── Scroll indicator ──────────────────────────────────── -->
  <div class="hero-scroll" id="hero-scroll">
    <span class="writing-vertical text-[9px] uppercase tracking-widest text-[var(--color-text-muted)]">
      {scrollText}
    </span>
    <div class="hero-scroll-bar">
      <div class="hero-scroll-fill animate-scroll-line"></div>
    </div>
  </div>

</section>

<style>
  /* ─── Sección base ──────────────────────────────────────────── */
  .hero-section {
    position: relative;
    width: 100%;
    height: 100svh;
    min-height: 600px;
    max-height: 1000px;
    overflow: hidden;
    background: var(--color-bg);
    display: flex;
    align-items: center;
  }

  /* ─── Mariposa ──────────────────────────────────────────────── */
  .hero-butterfly-zone {
    position: absolute;
    right: auto;
    left: 58%;
    top: 50%;
    transform: translateY(-50%);
    width: clamp(220px, 28vw, 400px);
    z-index: 1;
    pointer-events: none;
    opacity: 0;
    will-change: opacity, transform;
  }

  .hero-butterfly-main {
    display: block;
    width: 100%;
    height: auto;
    opacity: 0.55;
    filter: drop-shadow(0 20px 50px rgba(103, 6, 38, 0.11));
    animation: butterfly-hover 10s ease-in-out infinite;
    will-change: transform;
  }

  @keyframes butterfly-hover {
    0%, 100% { transform: translateY(0)     rotate(0deg)   scale(1);    }
    30%       { transform: translateY(-16px) rotate(2deg)   scale(1.01); }
    60%       { transform: translateY(-24px) rotate(-1.5deg) scale(1);   }
    80%       { transform: translateY(-8px)  rotate(1.5deg) scale(0.99); }
  }

  /* ─── Inner: flujo vertical, columna izquierda ──────────────── */
  .hero-inner {
    position: relative;
    z-index: 2;
    width: 100%;
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 0;
    padding: 0 1.5rem;
    /* En desktop: contenido ocupa solo la mitad izquierda */
    max-width: 100%;
  }

  @media (min-width: 768px) {
    .hero-inner { padding: 0 3rem; }
  }

  @media (min-width: 1024px) {
    .hero-inner {
      padding: 0 6rem;
      max-width: 68%;
    }
  }

  /* ─── Label de rol ──────────────────────────────────────────── */
  .hero-label {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    font-size: 0.68rem;
    font-weight: 400;
    letter-spacing: 0.32em;
    text-transform: uppercase;
    color: var(--color-text-muted);
    margin-bottom: 1.2rem;
    opacity: 0;
    transform: translateY(15px);
    will-change: transform, opacity;
  }

  .hero-label-line {
    display: inline-block;
    width: 1.75rem;
    height: 1px;
    background: var(--color-primary);
    flex-shrink: 0;
  }

  /* ─── Título ────────────────────────────────────────────────── */
  .hero-heading {
    font-family: var(--font-display);
    font-weight: 600;
    line-height: 1.0;
    letter-spacing: -0.025em;
    font-size: clamp(2.4rem, 5.2vw, 6.2rem);
    margin: 0 0 1.75rem 0;
  }

  /* Línea 1 (serif italic) — se escala para compensar el menor peso visual */
  .hero-heading-line:first-child {
    font-size: 1.15em;
    line-height: 1.05;
  }

  /* Línea 2 (display bold) — tamaño base */
  .hero-heading-line:last-child {
    line-height: 1.0;
  }

  .hero-heading-line {
    display: block;
  }

  .hero-word-wrap {
    display: inline-block;
    overflow: hidden;
    vertical-align: bottom;
    margin-right: 0.22em;
    line-height: 1.08;
    padding-bottom: 0.04em;
  }

  .hero-word {
    display: inline-block;
    opacity: 0;
    transform: translateY(105%);
    will-change: transform, opacity;
  }

  .hero-word--accent {
    color: var(--color-primary);
  }

  /* ─── Bloque inferior (desc + CTAs) — justo debajo del título ── */
  .hero-bottom-left {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
    opacity: 0;
    transform: translateY(18px);
    will-change: transform, opacity;
  }

  .hero-desc {
    font-size: clamp(0.82rem, 1.15vw, 0.95rem);
    line-height: 1.65;
    color: var(--color-text-muted);
    max-width: 42ch;
    margin: 0;
  }

  .hero-ctas {
    display: flex;
    flex-wrap: wrap;
    gap: 0.6rem;
    align-items: center;
  }

  .hero-btn-primary {
    padding: 0.65rem 1.5rem;
    background: var(--color-primary);
    color: #FDF8F3;
    font-size: 0.82rem;
    font-weight: 500;
    border-radius: 9999px;
    transition: box-shadow 0.3s ease;
  }

  .hero-btn-primary:hover {
    box-shadow: 0 6px 24px rgba(103, 6, 38, 0.28);
  }

  .hero-btn-ghost {
    padding: 0.65rem 1.5rem;
    border: 1px solid var(--color-border);
    color: var(--color-text);
    font-size: 0.82rem;
    font-weight: 500;
    border-radius: 9999px;
    transition: border-color 0.3s ease, color 0.3s ease;
  }

  .hero-btn-ghost:hover {
    border-color: var(--color-primary);
    color: var(--color-primary);
  }

  /* ─── Scroll indicator ──────────────────────────────────────── */
  .hero-scroll {
    position: absolute;
    bottom: 2rem;
    right: 1.5rem;
    display: flex;
    align-items: center;
    gap: 0.6rem;
    opacity: 0;
    will-change: opacity;
    z-index: 5;
  }

  @media (min-width: 768px)  { .hero-scroll { right: 3rem; } }
  @media (min-width: 1024px) { .hero-scroll { right: 6rem; } }

  .hero-scroll-bar {
    width: 1px;
    height: 3rem;
    background: var(--color-border);
    position: relative;
    overflow: hidden;
  }

  .hero-scroll-fill {
    position: absolute;
    inset: 0;
    background: var(--color-primary);
  }

  .writing-vertical {
    writing-mode: vertical-rl;
    text-orientation: mixed;
  }
</style>

<script>
  import gsap from 'gsap';

  function animateHero() {
    const label      = document.getElementById('hero-label');
    const words      = document.querySelectorAll<HTMLElement>('.hero-word');
    const bottomLeft = document.getElementById('hero-bottom-left');
    const butterfly  = document.getElementById('hero-butterfly-zone');
    const scroll     = document.getElementById('hero-scroll');

    const tl = gsap.timeline({ defaults: { ease: 'expo.out' } });

    // Label de rol
    if (label) tl.to(label, { opacity: 1, y: 0, duration: 0.7 }, 0.1);

    // Palabras del título — clip desde abajo, stagger
    if (words.length) {
      tl.to(words, { opacity: 1, y: '0%', duration: 0.8, stagger: 0.055 }, 0.2);
    }

    // Zona inferior (desc + CTAs)
    if (bottomLeft) tl.to(bottomLeft, { opacity: 1, y: 0, duration: 0.75 }, 0.55);

    // Mariposa — entra desde la derecha con fade
    if (butterfly) {
      tl.to(butterfly, {
        opacity: 1,
        x: 0,
        duration: 1.2,
        ease: 'expo.out',
      }, 0.2);
    }

    // Scroll indicator
    if (scroll) tl.to(scroll, { opacity: 1, duration: 0.6 }, 1.1);
  }

  // Estado inicial de la mariposa para GSAP
  const butterfly = document.getElementById('hero-butterfly-zone');
  if (butterfly) {
    butterfly.style.transform = 'translateY(-50%) translateX(50px)';
  }

  // Esperar al splash
  document.addEventListener('splashDone', animateHero);

  // Fallback
  let animated = false;
  document.addEventListener('splashDone', () => { animated = true; });
  setTimeout(() => {
    if (!animated) {
      document.documentElement.classList.add('splash-done');
      animateHero();
    }
  }, 200);
</script>
