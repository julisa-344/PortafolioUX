---
import ProjectCard from './ProjectCard.astro';
import type { Project } from './ProjectCard.astro';

interface Props {
  projects: Project[];
  title?: string;
  showViewAll?: boolean;
}

const { projects, title = "Proyectos Seleccionados", showViewAll = true } = Astro.props;
---

<section class="py-14 md:py-32 px-6 md:px-12 lg:px-24">
  <div class="max-w-[1600px] mx-auto">
    <!-- Section header -->
    <div class="flex flex-col md:flex-row md:items-end md:justify-between gap-6 mb-10 md:mb-16">
      <div>
        <p class="reveal text-[var(--color-text-muted)] text-sm uppercase tracking-[0.3em] mb-4" data-delay="0">
          Portfolio
        </p>
        <h2 class="reveal font-display text-3xl md:text-4xl lg:text-5xl font-semibold" data-delay="0.1">
          {title}
        </h2>
      </div>
      
      {showViewAll && (
        <a 
          href="/work" 
          class="reveal group inline-flex items-center gap-2 text-[var(--color-text-muted)] hover:text-[var(--color-primary)] transition-colors"
          data-delay="0.2"
        >
          <span class="text-sm uppercase tracking-wider">Ver todos</span>
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 transition-transform group-hover:translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
          </svg>
        </a>
      )}
    </div>

    <!-- Projects grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 md:gap-8">
      {projects.map((project, index) => (
        <div class="reveal" data-delay={0.1 + index * 0.1}>
          <ProjectCard project={project} index={index} />
        </div>
      ))}
    </div>
  </div>
</section>
