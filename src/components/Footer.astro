---
interface Props {
  class?: string;
}

const { class: className = '' } = Astro.props;

const currentYear = new Date().getFullYear();

const socialLinks = [
  {
    name: 'LinkedIn',
    url: 'https://www.linkedin.com/in/julisa-leon-front-ui/',
    icon: 'M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z'
  },
  {
    name: 'Behance',
    url: 'https://www.behance.net/julisaleon1',
    icon: 'M22 7h-7v-2h7v2zm1.726 10c-.442 1.297-2.029 3-5.101 3-3.074 0-5.564-1.729-5.564-5.675 0-3.91 2.325-5.92 5.466-5.92 3.082 0 4.964 1.782 5.375 4.426.078.506.109 1.188.095 2.14h-8.027c.13 3.211 3.483 3.312 4.588 2.029h3.168zm-7.686-4h4.965c-.105-1.547-1.136-2.219-2.477-2.219-1.466 0-2.277.768-2.488 2.219zm-9.574 6.988h-6.466v-14.967h6.953c5.476.081 5.58 5.444 2.72 6.906 3.461 1.26 3.577 8.061-3.207 8.061zm-3.466-8.988h3.584c2.508 0 2.906-3-.312-3h-3.272v3zm3.391 3h-3.391v3.016h3.341c3.055 0 2.868-3.016.05-3.016z'
  },
  {
    name: 'GitHub',
    url: 'https://github.com/julisa-344',
    icon: 'M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z'
  }
];
---

<footer class={`relative bg-[var(--color-primary)] overflow-hidden ${className}`}>

  <!-- ── TOP: CTA ── -->
  <div class="px-6 md:px-12 lg:px-24 pt-14 pb-8 relative z-10">
    <div class="max-w-[1600px] mx-auto grid grid-cols-1 lg:grid-cols-[1fr_auto] gap-12 items-end">

      <!-- Left: tagline + tagline-sub -->
      <div>
        <p class="reveal text-[#FDF8F3]/50 text-xs uppercase tracking-[0.3em] mb-5 flex items-center gap-3" data-delay="0">
          <span class="w-8 h-[1px] bg-[#FDF8F3]/30"></span>
          ¿Tienes un proyecto en mente?
        </p>
        <h2 class="reveal font-serif text-3xl md:text-4xl lg:text-5xl font-medium text-[#FDF8F3] italic leading-[1.1] mb-4" data-delay="0.1">
          Trabajemos juntos
        </h2>
        <p class="reveal text-[#FDF8F3]/60 text-sm md:text-base max-w-md leading-relaxed mb-6" data-delay="0.15">
          Convirtamos tus ideas en experiencias digitales que conectan y convierten.
        </p>
        <div class="reveal flex flex-wrap items-center gap-4" data-delay="0.2">
          <a
            href="mailto:julisa.leon344@gmail.com"
            target="_blank"
            rel="noopener noreferrer"
            class="group inline-flex items-center gap-3 px-7 py-3.5 bg-[#FDF8F3] text-[var(--color-primary)] font-medium rounded-full hover:bg-[var(--color-secondary)] transition-all duration-300 text-sm"
          >
            <span>Escribir un email</span>
            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 transition-transform duration-300 group-hover:translate-x-1 group-hover:-translate-y-1" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 17L17 7M17 7H7M17 7v10" />
            </svg>
          </a>
          <a
            href="/contact"
            class="group inline-flex items-center gap-3 px-7 py-3.5 border border-[#FDF8F3]/30 text-[#FDF8F3]/80 font-medium rounded-full hover:border-[#FDF8F3]/70 hover:text-[#FDF8F3] transition-all duration-300 text-sm"
          >
            <span>Ir a contacto</span>
            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 transition-transform duration-300 group-hover:translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
            </svg>
          </a>
        </div>
      </div>

      <!-- Right: nav columns -->
      <div class="reveal grid grid-cols-3 gap-10 text-sm" data-delay="0.2">
        <div>
          <p class="text-[#FDF8F3]/40 text-xs uppercase tracking-[0.25em] mb-4">Explorar</p>
          <ul class="space-y-3">
            <li><a href="/" class="text-[#FDF8F3]/70 hover:text-[#FDF8F3] transition-colors duration-200">Inicio</a></li>
            <li><a href="/work" class="text-[#FDF8F3]/70 hover:text-[#FDF8F3] transition-colors duration-200">Proyectos</a></li>
            <li><a href="/about" class="text-[#FDF8F3]/70 hover:text-[#FDF8F3] transition-colors duration-200">Sobre mí</a></li>
          </ul>
        </div>
        <div>
          <p class="text-[#FDF8F3]/40 text-xs uppercase tracking-[0.25em] mb-4">Contacto</p>
          <ul class="space-y-3">
            <li><a href="/contact" class="text-[#FDF8F3]/70 hover:text-[#FDF8F3] transition-colors duration-200">Formulario</a></li>
            <li><a href="mailto:julisa.leon344@gmail.com" target="_blank" rel="noopener noreferrer" class="text-[#FDF8F3]/70 hover:text-[#FDF8F3] transition-colors duration-200">Email</a></li>
          </ul>
        </div>
        <div>
          <p class="text-[#FDF8F3]/40 text-xs uppercase tracking-[0.25em] mb-4">Redes</p>
          <ul class="space-y-3">
            {socialLinks.map(s => (
              <li>
                <a href={s.url} target="_blank" rel="noopener noreferrer"
                  class="text-[#FDF8F3]/70 hover:text-[#FDF8F3] transition-colors duration-200 inline-flex items-center gap-2">
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-3 w-3 opacity-60" fill="currentColor" viewBox="0 0 24 24">
                    <path d={s.icon}/>
                  </svg>
                  {s.name}
                </a>
              </li>
            ))}
          </ul>
        </div>
      </div>

    </div>
  </div>

  <!-- ── BIG TYPE ── -->
  <div class="relative overflow-hidden leading-none select-none pointer-events-none" aria-hidden="true">
    <div class="px-6 md:px-12 lg:px-24">
      <div class="max-w-[1600px] mx-auto">
        <p class="font-serif font-medium italic text-[#FDF8F3]/[0.07] whitespace-nowrap"
          style="font-size: clamp(4rem, 12vw, 11rem); line-height: 0.85;">
          Julisa Leon
        </p>
      </div>
    </div>
  </div>

  <!-- ── BOTTOM BAR ── -->
  <div class="relative z-10 border-t border-[#FDF8F3]/10 px-6 md:px-12 lg:px-24 py-4">
    <div class="max-w-[1600px] mx-auto flex flex-col md:flex-row items-center justify-between gap-4">

      <!-- Logo -->
      <a href="/" class="group">
        <img src="/logo.svg" alt="Julisa Leon"
          class="h-7 w-auto opacity-70 group-hover:opacity-100 transition-opacity duration-300"
          style="filter: brightness(0) invert(1);"
        />
      </a>

      <!-- Social pills -->
      <div class="flex items-center gap-3">
        {socialLinks.map((social, index) => (
          <a
            href={social.url}
            target="_blank"
            rel="noopener noreferrer"
            class="flex items-center justify-center w-9 h-9 rounded-full border border-[#FDF8F3]/20 text-[#FDF8F3]/60 hover:text-[#FDF8F3] hover:border-[#FDF8F3]/50 hover:bg-[#FDF8F3]/10 transition-all duration-300"
            aria-label={social.name}
          >
            <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5" fill="currentColor" viewBox="0 0 24 24">
              <path d={social.icon}/>
            </svg>
          </a>
        ))}
      </div>

      <!-- Copyright -->
      <p class="text-[#FDF8F3]/40 text-xs flex items-center gap-2">
        <span>© {currentYear}</span>
        <span>•</span>
        <span>Diseñado y desarrollado con</span>
        <span class="text-[var(--color-secondary)]">&#10084;</span>
      </p>

    </div>
  </div>

</footer>
