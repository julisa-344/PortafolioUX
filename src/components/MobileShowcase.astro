---
import PhoneMockup from './PhoneMockup.astro';

interface MobileScreen {
  title: string;
  mobile: string;
  description?: string;
}

interface Props {
  title?: string;
  subtitle?: string;
  description?: string;
  screens: MobileScreen[];
}

const { 
  title = "Experiencia Mobile", 
  subtitle = "Responsive Design",
  screens 
} = Astro.props;
---

<section class="showcase-section py-24 bg-[var(--color-primary)] overflow-hidden">
  <div class="max-w-[1800px] mx-auto">

    <!-- ── Header ── -->
    <div class="text-center mb-16 px-6 md:px-12 lg:px-16">
      <p class="reveal text-[var(--color-secondary)] text-sm uppercase tracking-[0.3em] mb-4 flex items-center justify-center gap-3" data-delay="0">
        <span class="deco-pretitle-line"></span>
        {subtitle}
        <span class="deco-pretitle-line"></span>
      </p>
      <h2 class="reveal font-serif text-3xl md:text-5xl lg:text-6xl font-medium mb-0 text-[#FDF8F3]" data-delay="0.1">
        {title}
      </h2>
    </div>

    <!-- ── Carousel wrapper ── -->
    <div class="carousel-root relative">

      <!-- Fade izquierdo -->
      <div id="fade-left" class="fade-edge fade-edge-left pointer-events-none" aria-hidden="true"></div>
      <!-- Fade derecho -->
      <div id="fade-right" class="fade-edge fade-edge-right pointer-events-none" aria-hidden="true"></div>

      <!-- Botones de navegacion -->
      <button class="nav-btn nav-prev" aria-label="Anterior">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
        </svg>
      </button>

      <button class="nav-btn nav-next" aria-label="Siguiente">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
        </svg>
      </button>

      <!-- Track con scroll horizontal -->
      <div class="showcase-scroll" data-lenis-prevent>
        <div class="showcase-track">
          {screens.map((screen, index) => (
            <div 
              class="showcase-item"
              data-index={index}
            >
              <PhoneMockup src={screen.mobile} alt={`${screen.title} - Mobile`} />
              <p class="item-label">{screen.title}</p>
            </div>
          ))}
        </div>
      </div>
    </div>

    <!-- ── Dots de paginacion ── -->
    <div class="dots-wrapper" aria-label="Navegacion de pantallas">
      {screens.map((_, i) => (
        <button
          class:list={["dot", { "dot-active": i === 0 }]}
          data-dot={i}
          aria-label={`Ir a pantalla ${i + 1}`}
        ></button>
      ))}
    </div>

  </div>
</section>

<style>
  /* ── Seccion ── */
  .showcase-section {
    position: relative;
  }

  @media (max-width: 767px) {
    .showcase-section {
      padding-top: 3.5rem;
      padding-bottom: 3.5rem;
    }
  }

  /* ── Linea decorativa del pretitle ── */
  .deco-pretitle-line {
    display: block;
    flex-shrink: 0;
    width: 2rem;
    height: 1px;
    background: var(--color-secondary);
    opacity: 0.7;
  }

  /* ── Carousel root ── */
  .carousel-root {
    position: relative;
    /* padding horizontal para que los botones queden pegados al scroll container */
    padding: 0 3.5rem;
    /* Limitar ancho: 3 items + 2 gaps + peek ~80px + botones (2×3.5rem) */
    max-width: 1190px;  /* lg: 3×290 + 2×28 + 80 + 112 ≈ 1186px */
    margin-left: auto;
    margin-right: auto;
  }

  @media (min-width: 1280px) {
    .carousel-root {
      max-width: 1250px; /* xl: 3×310 + 2×32 + 80 + 112 ≈ 1250px */
    }
  }

  @media (max-width: 767px) {
    .carousel-root {
      padding: 0 2.75rem;
      max-width: 100%;
    }
  }

  /* ── Fades laterales ── */
  .fade-edge {
    position: absolute;
    top: 0;
    bottom: 0;
    width: 120px;
    z-index: 10;
    pointer-events: none;
    transition: opacity 0.3s ease;
  }

  .fade-edge-left {
    left: 0;
    background: linear-gradient(to right, var(--color-primary) 20%, transparent);
    opacity: 0; /* Oculto al inicio */
  }

  .fade-edge-right {
    right: 0;
    background: linear-gradient(to left, var(--color-primary) 20%, transparent);
    opacity: 1;
  }

  /* ── Botones navegacion ── */
  .nav-btn {
    display: flex;
    position: absolute;
    top: 42%; /* Centrado vertical en el area del telefono */
    transform: translateY(-50%);
    z-index: 20;
    width: 36px;
    height: 36px;
    border-radius: 50%;
    background: rgba(253, 248, 243, 0.1);
    border: 1.5px solid rgba(253, 248, 243, 0.3);
    color: #FDF8F3;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: background 0.25s ease, border-color 0.25s ease, color 0.25s ease, transform 0.25s ease, opacity 0.3s ease;
  }

  .nav-btn:hover {
    background: var(--color-secondary);
    border-color: var(--color-secondary);
    color: var(--color-primary);
    transform: translateY(-50%) scale(1.08);
  }

  .nav-btn:disabled {
    opacity: 0.25;
    pointer-events: none;
  }

  .nav-prev { left: 0; }
  .nav-next { right: 0; }

  @media (min-width: 768px) {
    .nav-btn {
      width: 48px;
      height: 48px;
    }
  }

  /* ── Scroll container ── */
  .showcase-scroll {
    overflow-x: auto;
    overflow-y: hidden;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
    -ms-overflow-style: none;
    cursor: grab;
    /* Sin scroll-snap: el JS maneja todo el posicionamiento */
    will-change: scroll-position;
    max-width: 100%;
  }

  .showcase-scroll::-webkit-scrollbar { display: none; }
  .showcase-scroll:active { cursor: grabbing; }

  /* ── Track ── */
  .showcase-track {
    display: flex;
    gap: 2.5rem;
    /* padding lateral minimo — el JS agrega el padding-right dinamico para el ultimo item */
    padding: 3rem 0 3rem 2.5rem;
    width: max-content;
    align-items: center;
  }

  /* ── Item individual ── */
  .showcase-item {
    flex-shrink: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.25rem;
    width: 160px;
    /* Sin scroll-snap — el JS posiciona */
    transition:
      transform 0.45s cubic-bezier(0.16, 1, 0.3, 1),
      opacity  0.45s cubic-bezier(0.16, 1, 0.3, 1);
    transform: scale(0.88);
    opacity: 0.55;
  }

  .showcase-item.is-active {
    transform: scale(1.04);
    opacity: 1;
  }

  /* ── Etiqueta debajo ── */
  .item-label {
    font-family: var(--font-serif);
    font-size: 1rem;
    font-style: italic;
    color: rgba(253, 248, 243, 0.6);
    text-align: center;
    letter-spacing: 0.02em;
    transition: color 0.35s ease, opacity 0.35s ease;
    opacity: 0.6;
  }

  .showcase-item.is-active .item-label {
    color: #FDF8F3;
    opacity: 1;
  }

  /* ── Responsive sizes ──
     Mobile (< 480px): 1 device fills the view exactly
     scroll container = 100vw - 2×2.75rem (button padding)
     item = scroll container - track padding-left (2.5rem)
     → calc(100vw - 8rem) fills it perfectly
  ── */
  @media (max-width: 479px) {
    /* Carousel: buttons outside, scroll area fills the rest */
    .carousel-root { padding: 0 2.5rem; }
    /* Track: no horizontal padding, items centered via JS */
    .showcase-track {
      gap: 2rem;
      padding: 2rem 0;
      /* Equal padding so every item can be centered */
    }
    /* Fixed small width — phone aspect-ratio handles height */
    .showcase-item {
      width: 180px;
    }
    .showcase-item.is-active { transform: scale(1); }
    .fade-edge { display: none; }
    /* Smaller nav buttons */
    .nav-btn { width: 32px; height: 32px; }
    .nav-btn svg { width: 14px; height: 14px; }
  }

  @media (min-width: 480px) {
    .showcase-item { width: 190px; }
  }

  @media (min-width: 640px) {
    .showcase-item { width: 220px; }
  }

  @media (min-width: 1024px) {
    .showcase-item { width: 290px; }
    .showcase-track {
      gap: 1.75rem;
      padding: 3rem 0 3rem 2.5rem;
    }
  }

  @media (min-width: 1280px) {
    .showcase-item { width: 310px; }
    .showcase-track { gap: 2rem; padding: 3rem 0 3rem 3rem; }
  }

  /* ── Dots ── */
  .dots-wrapper {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.6rem;
    margin-top: 2.5rem;
    padding-bottom: 0.5rem;
  }

  .dot {
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: rgba(253, 248, 243, 0.3);
    border: none;
    cursor: pointer;
    padding: 0;
    transition: background 0.3s ease, transform 0.3s ease, width 0.3s ease;
    flex-shrink: 0;
  }

  .dot.dot-active {
    background: var(--color-secondary);
    width: 22px;
    border-radius: 4px;
    transform: none;
  }

  .dot:hover:not(.dot-active) {
    background: rgba(253, 248, 243, 0.6);
    transform: scale(1.2);
  }
</style>

<script>
  document.querySelectorAll('.showcase-section').forEach(section => {
    const scroll    = section.querySelector('.showcase-scroll') as HTMLElement;
    const track     = section.querySelector('.showcase-track') as HTMLElement;
    const items     = Array.from(section.querySelectorAll('.showcase-item')) as HTMLElement[];
    const dots      = Array.from(section.querySelectorAll('.dot')) as HTMLButtonElement[];
    const prevBtn   = section.querySelector('.nav-prev') as HTMLButtonElement;
    const nextBtn   = section.querySelector('.nav-next') as HTMLButtonElement;
    const fadeLeft  = section.querySelector('.fade-edge-left')  as HTMLElement;
    const fadeRight = section.querySelector('.fade-edge-right') as HTMLElement;

    if (!scroll || !items.length) return;

    let activeIndex = 0;

    // ── Padding dinamico para que TODOS los items puedan centrarse ──
    // Agrega padding-left y padding-right iguales = mitad del scroll menos mitad del item
    const updateEdgePadding = () => {
      if (!items.length) return;
      const firstItem = items[0];
      const lastItem  = items[items.length - 1];
      const padLeft  = Math.max(0, scroll.clientWidth / 2 - firstItem.offsetWidth / 2);
      const padRight = Math.max(0, scroll.clientWidth / 2 - lastItem.offsetWidth / 2);
      track.style.paddingLeft  = padLeft  + 'px';
      track.style.paddingRight = padRight + 'px';
    };

    // ── Activar item ──
    const setActive = (index: number) => {
      activeIndex = Math.max(0, Math.min(index, items.length - 1));
      items.forEach((item, i) => item.classList.toggle('is-active', i === activeIndex));
      dots.forEach((dot, i)   => dot.classList.toggle('dot-active',  i === activeIndex));
      if (prevBtn) prevBtn.disabled = activeIndex === 0;
      if (nextBtn) nextBtn.disabled = activeIndex === items.length - 1;
    };

    // ── Calcular item mas cercano al centro del scroll container ──
    // Usa offsetLeft (relativo al track) + scrollLeft para obtener posicion absoluta
    // Caso especial: item 0 cuando scroll ≈ 0, item final cuando scroll ≈ scrollWidth
    const getNearestIndex = (): number => {
      const scrolled  = scroll.scrollLeft;
      const viewHalf  = scroll.clientWidth / 2;
      const center    = scrolled + viewHalf;

      // Caso borde izquierdo: si el scroll esta muy cerca del inicio, es el item 0
      if (scrolled < 20) return 0;

      // Caso borde derecho: si el scroll esta muy cerca del final, es el ultimo item
      const atEnd = scrolled >= scroll.scrollWidth - scroll.clientWidth - 20;
      if (atEnd) return items.length - 1;

      // Caso general: item cuyo centro este mas cerca del centro del viewport
      let nearest = 0;
      let minDist = Infinity;
      items.forEach((item, i) => {
        // offsetLeft del item es relativo al track, que tiene paddingLeft = 2rem = 32px
        const itemCenter = item.offsetLeft + item.offsetWidth / 2;
        const dist = Math.abs(center - itemCenter);
        if (dist < minDist) { minDist = dist; nearest = i; }
      });
      return nearest;
    };

    // ── Scroll programatico al item (siempre centrado) ──
    const scrollToItem = (index: number) => {
      const clamped = Math.max(0, Math.min(index, items.length - 1));
      const item    = items[clamped];
      if (!item) return;

      // Siempre centrar: target = centro del item - mitad del viewport
      const target = item.offsetLeft + item.offsetWidth / 2 - scroll.clientWidth / 2;
      scroll.scrollTo({ left: Math.max(0, target), behavior: 'smooth' });
      setActive(clamped);
    };

    // ── Actualizar UI en scroll ──
    let scrollEndTimer = 0;
    scroll.addEventListener('scroll', () => {
      // Fades y botones en tiempo real
      const scrolled = scroll.scrollLeft;
      const atEnd    = scrolled >= scroll.scrollWidth - scroll.clientWidth - 4;
      if (fadeLeft)  fadeLeft.style.opacity  = scrolled > 10 ? '1' : '0';
      if (fadeRight) fadeRight.style.opacity = atEnd         ? '0' : '1';
      if (prevBtn)   prevBtn.disabled = scrolled <= 0;
      if (nextBtn)   nextBtn.disabled = atEnd;

      // Foco: actualizar cuando el scroll se detiene (150ms sin scroll)
      clearTimeout(scrollEndTimer);
      scrollEndTimer = window.setTimeout(() => {
        setActive(getNearestIndex());
      }, 150);
    }, { passive: true });

    // ── Botones ──
    prevBtn?.addEventListener('click', () => scrollToItem(activeIndex - 1));
    nextBtn?.addEventListener('click', () => scrollToItem(activeIndex + 1));

    // ── Dots ──
    dots.forEach((dot, i) => dot.addEventListener('click', () => scrollToItem(i)));

    // ── Drag to scroll con momentum ──
    let isDown     = false;
    let startX     = 0;
    let scrollLeft = 0;
    let velocity   = 0;
    let lastX      = 0;
    let momentumID = 0;

    const cancelMomentum = () => cancelAnimationFrame(momentumID);
    const startMomentum  = () => {
      cancelMomentum();
      const loop = () => {
        velocity *= 0.93;
        if (Math.abs(velocity) > 0.5) {
          scroll.scrollLeft -= velocity;
          momentumID = requestAnimationFrame(loop);
        }
      };
      momentumID = requestAnimationFrame(loop);
    };

    scroll.addEventListener('mousedown', (e) => {
      isDown     = true;
      startX     = e.pageX - scroll.offsetLeft;
      scrollLeft = scroll.scrollLeft;
      lastX      = startX;
      velocity   = 0;
      cancelMomentum();
    }, { passive: true });

    scroll.addEventListener('mouseleave', () => { if (isDown) { isDown = false; startMomentum(); } });
    scroll.addEventListener('mouseup',    () => { if (isDown) { isDown = false; startMomentum(); } });
    scroll.addEventListener('mousemove', (e) => {
      if (!isDown) return;
      e.preventDefault();
      const x       = e.pageX - scroll.offsetLeft;
      velocity      = x - lastX;
      lastX         = x;
      scroll.scrollLeft = scrollLeft - (x - startX) * 1.4;
    }, { passive: false });

    // ── Touch ──
    let touchStartX     = 0;
    let touchScrollLeft = 0;

    scroll.addEventListener('touchstart', (e) => {
      touchStartX     = e.touches[0].pageX;
      touchScrollLeft = scroll.scrollLeft;
      cancelMomentum();
    }, { passive: true });

    scroll.addEventListener('touchmove', (e) => {
      scroll.scrollLeft = touchScrollLeft + (touchStartX - e.touches[0].pageX) * 1.2;
    }, { passive: true });

    // ── Init ──
    const init = () => {
      updateEdgePadding();
      // Center first item
      scrollToItem(0);
      setActive(0);
      if (fadeLeft)  fadeLeft.style.opacity  = '0';
      if (fadeRight) fadeRight.style.opacity = items.length > 1 ? '1' : '0';
      if (prevBtn)   prevBtn.disabled = true;
      if (nextBtn)   nextBtn.disabled = items.length <= 1;
    };

    if (document.readyState === 'complete') {
      init();
    } else {
      window.addEventListener('load', init, { once: true });
    }

    window.addEventListener('resize', () => {
      updateEdgePadding();
      scrollToItem(0);
      setActive(0);
    });
  });
</script>
